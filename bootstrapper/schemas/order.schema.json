{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genai-vanilla/schemas/order.schema.json",
  "title": "Service Order",
  "description": "Schema for services/_order.yml. Declares the canonical service ordering for stable .env.example diffs and the wizard's display order.",
  "type": "object",
  "additionalProperties": false,
  "required": ["order"],
  "properties": {
    "order": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "category"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
            "description": "Must match an existing services/<name>/ folder."
          },
          "category": {
            "type": "string",
            "enum": ["data", "llm", "ai", "app", "infra"],
            "description": "Wizard grouping; should match the manifest's own category."
          }
        }
      }
    }
  }
}
