digraph stack {
  rankdir=TB;
  bgcolor="#0e0f18";
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontcolor="#c0caf5", color="#2b2f4a"];
  edge [color="#3d4261"];

  subgraph "cluster_infra" {
    label="Infrastructure";
    fontcolor="#f38ba8";
    color="#f38ba8";
    "globals" [fillcolor="#f38ba833"];
    "kong" [fillcolor="#f38ba833"];
  }

  subgraph "cluster_data" {
    label="Data";
    fontcolor="#a6e3a1";
    color="#a6e3a1";
    "supabase" [fillcolor="#a6e3a133"];
    "minio" [fillcolor="#a6e3a133"];
    "neo4j" [fillcolor="#a6e3a133"];
    "redis" [fillcolor="#a6e3a133"];
    "weaviate" [fillcolor="#a6e3a133"];
  }

  subgraph "cluster_llm" {
    label="LLM Core";
    fontcolor="#cba6f7";
    color="#cba6f7";
    "litellm" [fillcolor="#cba6f733"];
    "cloud-providers" [fillcolor="#cba6f733"];
    "ollama" [fillcolor="#cba6f733"];
  }

  subgraph "cluster_media" {
    label="Media";
    fontcolor="#f9e2af";
    color="#f9e2af";
    "docling" [fillcolor="#f9e2af33"];
    "comfyui" [fillcolor="#f9e2af33"];
    "parakeet" [fillcolor="#f9e2af33"];
    "searxng" [fillcolor="#f9e2af33"];
    "tts-provider" [fillcolor="#f9e2af33"];
    "chatterbox" [fillcolor="#f9e2af33"];
    "speaches" [fillcolor="#f9e2af33"];
  }

  subgraph "cluster_agents" {
    label="Agents & Workflows";
    fontcolor="#89b4fa";
    color="#89b4fa";
    "hermes" [fillcolor="#89b4fa33"];
    "n8n" [fillcolor="#89b4fa33"];
    "openclaw" [fillcolor="#89b4fa33"];
  }

  subgraph "cluster_apps" {
    label="Apps & UIs";
    fontcolor="#fab387";
    color="#fab387";
    "backend" [fillcolor="#fab38733"];
    "jupyterhub" [fillcolor="#fab38733"];
    "open-webui" [fillcolor="#fab38733"];
    "local-deep-researcher" [fillcolor="#fab38733"];
  }

  "supabase" -> "backend";
  "redis" -> "backend";
  "tts-provider" -> "chatterbox";
  "litellm" -> "cloud-providers";
  "supabase" -> "comfyui";
  "litellm" -> "comfyui";
  "ollama" -> "comfyui";
  "globals" -> "docling";
  "litellm" -> "hermes";
  "supabase" -> "jupyterhub";
  "redis" -> "jupyterhub";
  "litellm" -> "jupyterhub";
  "supabase" -> "kong";
  "redis" -> "kong";
  "litellm" -> "kong";
  "open-webui" -> "kong";
  "n8n" -> "kong";
  "hermes" -> "kong";
