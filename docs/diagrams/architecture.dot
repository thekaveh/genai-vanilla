digraph stack {
  rankdir=TB;
  bgcolor="#0e0f18";
  node [shape=box, style="filled,rounded", fontname="Helvetica", fontcolor="#c0caf5", color="#2b2f4a"];
  edge [color="#3d4261"];

  subgraph "cluster_infra" {
    label="Infrastructure";
    fontcolor="#f7768e";
    color="#f7768e";
    "globals" [fillcolor="#f7768e33"];
    "kong" [fillcolor="#f7768e33"];
  }

  subgraph "cluster_data" {
    label="Data";
    fontcolor="#7dcfff";
    color="#7dcfff";
    "supabase" [fillcolor="#7dcfff33"];
    "minio" [fillcolor="#7dcfff33"];
    "neo4j" [fillcolor="#7dcfff33"];
    "redis" [fillcolor="#7dcfff33"];
    "weaviate" [fillcolor="#7dcfff33"];
  }

  subgraph "cluster_llm" {
    label="LLM Core";
    fontcolor="#e0af68";
    color="#e0af68";
    "litellm" [fillcolor="#e0af6833"];
    "cloud-providers" [fillcolor="#e0af6833"];
    "ollama" [fillcolor="#e0af6833"];
  }

  subgraph "cluster_media" {
    label="Media";
    fontcolor="#7aa2f7";
    color="#7aa2f7";
    "docling" [fillcolor="#7aa2f733"];
    "comfyui" [fillcolor="#7aa2f733"];
    "parakeet" [fillcolor="#7aa2f733"];
    "searxng" [fillcolor="#7aa2f733"];
    "tts-provider" [fillcolor="#7aa2f733"];
    "chatterbox" [fillcolor="#7aa2f733"];
    "speaches" [fillcolor="#7aa2f733"];
  }

  subgraph "cluster_agents" {
    label="Agents & Workflows";
    fontcolor="#9ece6a";
    color="#9ece6a";
    "hermes" [fillcolor="#9ece6a33"];
    "n8n" [fillcolor="#9ece6a33"];
    "openclaw" [fillcolor="#9ece6a33"];
  }

  subgraph "cluster_apps" {
    label="Apps & UIs";
    fontcolor="#bb9af7";
    color="#bb9af7";
    "backend" [fillcolor="#bb9af733"];
    "jupyterhub" [fillcolor="#bb9af733"];
    "open-webui" [fillcolor="#bb9af733"];
    "local-deep-researcher" [fillcolor="#bb9af733"];
  }

  "supabase" -> "backend";
  "redis" -> "backend";
  "litellm" -> "backend";
  "tts-provider" -> "chatterbox";
  "litellm" -> "cloud-providers";
  "supabase" -> "comfyui";
  "litellm" -> "comfyui";
  "ollama" -> "comfyui";
  "litellm" -> "hermes";
  "supabase" -> "jupyterhub";
  "redis" -> "jupyterhub";
  "litellm" -> "jupyterhub";
  "supabase" -> "kong";
  "redis" -> "kong";
  "supabase" -> "litellm";
  "redis" -> "litellm";
  "supabase" -> "local-deep-researcher";
  "searxng" -> "local-deep-researcher";
  "litellm" -> "local-deep-researcher";
  "supabase" -> "minio";
  "supabase" -> "n8n";
  "redis" -> "n8n";
  "litellm" -> "n8n";
  "supabase" -> "neo4j";
  "supabase" -> "ollama";
  "litellm" -> "ollama";
  "supabase" -> "open-webui";
  "redis" -> "open-webui";
  "litellm" -> "open-webui";
  "litellm" -> "openclaw";
  "litellm" -> "parakeet";
  "supabase" -> "redis";
  "supabase" -> "searxng";
  "redis" -> "searxng";
  "parakeet" -> "speaches";
  "tts-provider" -> "speaches";
  "litellm" -> "tts-provider";
  "supabase" -> "weaviate";
  "litellm" -> "weaviate";
}
