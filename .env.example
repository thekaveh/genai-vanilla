# ============================================================================
# GENERATED FILE — DO NOT EDIT BY HAND
#
# This .env.example is produced by bootstrapper/services/env_assembler.py
# from services/<name>/service.yml manifests. To change a default, edit the
# relevant manifest and re-run `./start.sh` (which regenerates this file)
# or `python -m services.env_assembler` for the regen-only path.
#
# Variables flagged `auto-managed` are computed at runtime by the bootstrapper
# from SOURCE values and are intentionally emitted without a default here.
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────
# agents: Apache Airflow (DAG orchestrator)  (services/airflow/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | disabled
AIRFLOW_SOURCE=disabled

# Image references
AIRFLOW_IMAGE=apache/airflow:3.2.2

# Host port for the Airflow Web UI + REST API (in-container 8080).
AIRFLOW_PORT=63060
AIRFLOW_DB_USER=airflow
# Auto-generated by bootstrapper. Postgres role for the Airflow metadata DB.
# (secret)
AIRFLOW_DB_PASSWORD=
# Auto-generated. Fernet key for encrypting Connection passwords.
# (secret)
AIRFLOW_FERNET_KEY=
# Auto-generated. AIRFLOW__API__SECRET_KEY — signs inter-process payloads (DagFileProcessor → scheduler RPC, deferrable triggers, multi-scheduler JWTs). Airflow 3.x; previously [webserver] secret_key + Flask sessions in 2.x.
# (secret)
AIRFLOW_SECRET_KEY=
# Auto-generated. Admin login. Username is hardcoded 'admin'.
# (secret)
AIRFLOW_ADMIN_PASSWORD=
# (auto-managed)
AIRFLOW_WEBSERVER_SCALE=
# (auto-managed)
AIRFLOW_SCHEDULER_SCALE=
# Required in Airflow 3.x — the standalone DAG processor service parses DAG files into the metadata DB (the scheduler no longer does this in-process).
# (auto-managed)
AIRFLOW_DAG_PROCESSOR_SCALE=
# (auto-managed)
AIRFLOW_INIT_SCALE=
# Container memory limit for airflow-webserver (deploy.resources.limits.memory). The api-server process is Python + Flask/FAB; 2 g is comfortable on a 32 GB host and prevents runaway memory from large DAG list pages.
AIRFLOW_WEBSERVER_MEMORY_LIMIT=2g
# Container CPU limit for airflow-webserver (deploy.resources.limits.cpus). 1.0 core is ample for the API/UI server under typical load.
AIRFLOW_WEBSERVER_CPU_LIMIT=1.0
# Container memory limit for airflow-scheduler (deploy.resources.limits.memory). The LocalExecutor scheduler forks task processes in-process; 2 g caps runaway task forking.
AIRFLOW_SCHEDULER_MEMORY_LIMIT=2g
# Container CPU limit for airflow-scheduler (deploy.resources.limits.cpus). 1.0 core is sufficient for LocalExecutor task scheduling on a dev/staging host.
AIRFLOW_SCHEDULER_CPU_LIMIT=1.0
# Container memory limit for airflow-dag-processor (deploy.resources.limits.memory). DAG parsing is Python-heavy but short-lived per cycle; 2 g prevents unbounded growth from parsing pathological DAG files.
AIRFLOW_DAG_PROCESSOR_MEMORY_LIMIT=2g
# Container CPU limit for airflow-dag-processor (deploy.resources.limits.cpus). 1.0 core covers the periodic DAG file parsing cycle.
AIRFLOW_DAG_PROCESSOR_CPU_LIMIT=1.0

# ──────────────────────────────────────────────────────────────────────────
# apps: Backend API (FastAPI)  (services/backend/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
BACKEND_IMAGE=python:3.12.13

# Adaptive core service; always container. Single-option.
BACKEND_SOURCE=container
BACKEND_PORT=63080
# Always 1 (BACKEND_SOURCE is single-valued).
# (auto-managed)
BACKEND_SCALE=
LANGMEM_ENABLED=true
LANGMEM_MEMORY_NAMESPACE=default
# Reserved — not yet honored. Memory consolidation currently runs only
# on demand via POST /memory/consolidate; there is no background
# scheduler, so changing this value has no effect today.
LANGMEM_AUTO_CONSOLIDATE=true
# Reserved — not yet honored (see LANGMEM_AUTO_CONSOLIDATE). Interval in
# seconds a future auto-consolidation scheduler would use.
LANGMEM_CONSOLIDATION_INTERVAL=86400
LANGMEM_MAX_FACTS_PER_USER=1000
# LiteLLM model id (empty = highest-priority active content model resolved by model_resolver from YAML catalogs + env).
LANGMEM_EXTRACTION_MODEL=
LANGMEM_EMBEDDING_MODEL=

# ──────────────────────────────────────────────────────────────────────────
# infra: Backup / restore (Postgres + volumes -> S3)  (services/backup/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | disabled
BACKUP_SOURCE=disabled

# Image references
# Provides pg_dump/pg_restore; the major version must be >= the supabase-db server (17.x) or pg_dump aborts on a server-version mismatch. Alpine minio-client (mcli) is installed inline via apk; entrypoint symlinks mcli -> mc so the backup scripts work unchanged.
BACKUP_IMAGE=postgres:17.10-alpine

# Target bucket for backups.
BACKUP_BUCKET=atlas-backups
# S3 endpoint. Default = on-box MinIO; set to an external S3 URL for offsite.
BACKUP_S3_ALIAS_URL=http://minio:9000
# 0 (never long-running); the runner is invoked on demand via docker compose run.
# (auto-managed)
BACKUP_SCALE=

# ──────────────────────────────────────────────────────────────────────────
# media: Chatterbox (voice-cloning TTS, GPU)  (services/chatterbox/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
# Rolling :gpu tag. Pin to a digest in production via `docker pull travisvn/chatterbox-tts-api:gpu` + paste the digest.
CHATTERBOX_IMAGE=travisvn/chatterbox-tts-api:gpu

# Host port for the Chatterbox container (in-container listen port is 4123).
CHATTERBOX_PORT=63045
# Host port for the localhost source variant (defaults to the freed TTS_PROVIDER_PORT slot). URL is derived at compose-render time as http://host.docker.internal:63044.
CHATTERBOX_LOCALHOST_PORT=63044
# Computed by bootstrapper/services/service_config.py::_generate_tts_provider_config — set to 1 when TTS_PROVIDER_SOURCE=chatterbox-container-gpu.
# (auto-managed)
CHATTERBOX_SCALE=

