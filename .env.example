DOCLING_GPU_IMAGE=pytorch/pytorch:2.12.1-cuda12.6-cudnn9-runtime

DOC_PROCESSOR_PORT=63040
DOCLING_GPU_DEVICE=cuda
DOCLING_OUTPUT_FORMAT=markdown
DOCLING_USE_OCR=auto
DOCLING_TABLE_MODE=accurate
DOCLING_MAX_FILE_SIZE=52428800
DOCLING_ENABLE_FORMULAS=true
DOCLING_ENABLE_CODE_BLOCKS=true
DOCLING_CHUNK_SIZE=512
DOCLING_CHUNK_OVERLAP=50
# (auto-managed)
DOCLING_GPU_SCALE=
# (auto-managed)
DOCLING_ENDPOINT=
# Host port for the localhost source variant (defaults to the freed DOC_PROCESSOR_PORT slot). URL is derived at compose-render time as http://host.docker.internal:63040.
DOCLING_LOCALHOST_PORT=63040

# ──────────────────────────────────────────────────────────────────────────
# infra: Globals (project + branding)  (services/globals/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Docker Compose project name — the container/volume/network prefix (<name>-…) and `docker compose -p` namespace. start.sh AND stop.sh read it from here, so stop tears down exactly what start launched. Override with `./start.sh --project <name>` (also -p; persists back here) or by editing this value. Set a unique name when running Atlas as a submodule so you don't collide with a base Atlas stack.
PROJECT_NAME=atlas
# Base port. Every service's *_PORT derives from this + a fixed offset.
BASE_PORT=63000
# Host interface prefix for ALL published service ports. Empty (default)
# => Docker binds 0.0.0.0 (dev). `--profile prod` sets this to
# "127.0.0.1:" so service ports are reachable only from the host (the
# public edge — Cloudflare Tunnel or Caddy — reaches Kong locally).
# Must include the trailing colon when set, e.g. "127.0.0.1:".
HOST_BIND_IP=
# Bootstrapper computes this at runtime based on the runtime (Docker:
# "host-gateway"; Podman: literal gateway IP). If you copy this file to
# .env manually without running ./start.sh, set this to "host-gateway"
# on Linux/macOS Docker, or the real bridge IP on rootless setups.
# (auto-managed)
HOST_GATEWAY_IP=
BRAND_NAME=Atlas
BRAND_TAGLINE=A self-hosted, source-configurable, multi-disciplinary engineering platform — gen-AI, ML, and data.
BRAND_VERSION=0.1.0
BRAND_AUTHOR=Kaveh Razavi
BRAND_AUTHOR_EMAIL=kaveh.razavi@gmail.com
BRAND_LICENSE=Apache License 2.0
BRAND_REPO_URL=https://github.com/thekaveh/atlas
# Optional path to a custom block-art logo that overrides the built-in ATLAS lockup in the wizard + --no-tui banner (the BRAND_* rebranding contract). File format: the wide-lockup rows, an optional '---' line on its own, then the narrow (compact) fallback rows used on terminals too small for the wide one. Keep it 6 rows tall. Empty = built-in ATLAS. Format + example: docs/quick-start/interactive-setup-wizard.md (Brand Customization).
BRAND_LOGO_FILE=
# Docker Compose profile activation list. Rebuilt from scratch on every
# ./start.sh run from the active STT/TTS/doc-processor sources
# (speaches-cpu/-gpu, parakeet-gpu, chatterbox-gpu, docling-gpu/doc-gpu).
# Do not edit by hand — the bootstrapper owns this value.
# (auto-managed)
COMPOSE_PROFILES=
# Host-side GPU visibility. Forwarded into every NVIDIA-runtime container.
NVIDIA_VISIBLE_DEVICES=all
# Default container CPU cap (cores). Per-service overrides below.
PROD_ENV_CPUS=2
PROD_ENV_MEM_LIMIT=8g
PROD_ENV_BACKEND_CPUS=1
PROD_ENV_BACKEND_MEM_LIMIT=2g
PROD_ENV_N8N_CPUS=1
PROD_ENV_N8N_MEM_LIMIT=2g
PROD_ENV_COMFYUI_CPUS=2
PROD_ENV_COMFYUI_MEM_LIMIT=4g
# Per-container json-file log max size (Docker logging option).
LOG_MAX_SIZE=10m
# Per-container json-file log file count (Docker logging option).
LOG_MAX_FILE=3
# Sentinel updated by bootstrapper/services/migrations. Missing or <N triggers the chained env migrations up to N (v1 port-layout, v2 URL>PORT, v3 COMFYUI model-set). Fresh .env files are already v3-shaped.
BOOTSTRAPPER_PORT_LAYOUT_VERSION=3

# ──────────────────────────────────────────────────────────────────────────
# infra: Grafana (observability UI + alerting)  (services/grafana/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | disabled
GRAFANA_SOURCE=disabled

# Image references
GRAFANA_IMAGE=grafana/grafana:11.4.3

# Host port for Grafana's HTTP server (in-container 3000).
GRAFANA_PORT=63008
# Grafana admin login. Override in .env if needed.
GRAFANA_ADMIN_USERNAME=admin
# Auto-generated on first bootstrap by generate_grafana_admin_password() (mirrors LiteLLM UI_PASSWORD pattern). Persisted to .env; users can rotate by editing .env and restarting.
GRAFANA_ADMIN_PASSWORD=
# (auto-managed)
GRAFANA_ENDPOINT=
# (auto-managed)
GRAFANA_SCALE=

# ──────────────────────────────────────────────────────────────────────────
# agents: Hermes (programmable AI agent)  (services/hermes/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | localhost | disabled
HERMES_SOURCE=container

# Image references
HERMES_IMAGE=nousresearch/hermes-agent:v2026.6.19
HERMES_INIT_IMAGE=alpine:3.24.1

# Host port for the Hermes Agent OpenAI-compatible API (in-container listen port is 8642).
HERMES_API_PORT=63061
# Host port for the Hermes Agent web dashboard (in-container listen port is 9119).
HERMES_DASHBOARD_PORT=63062
HERMES_MEMORY_LIMIT=4g
HERMES_CPU_LIMIT=2.0
# Auto-generated by bootstrapper. Forwarded to LiteLLM via API_SERVER_KEY.
# (secret)
HERMES_API_KEY=
# Empty = hermes-init picks from LiteLLM /v1/models priority list.
HERMES_DEFAULT_MODEL=
HERMES_CONTEXT_LENGTH=65536
HERMES_DASHBOARD_ENABLED=true
# Embed PTY-backed Chat tab in dashboard. 1 = on, 0 = read-only.
HERMES_DASHBOARD_TUI=1
# Allow the dashboard to bind to its non-loopback container address (0.0.0.0) without a Nous Portal OAuth provider. Required since the upstream image stopped implicitly inferring insecure mode from the bind host; without it the dashboard fails closed and s6 restart-loops it. Safe here: the dashboard binds inside the isolated backend-network and is only reachable via the localhost host-port + Kong. Set to false (and provide HERMES_DASHBOARD_OAUTH_CLIENT_ID) to enforce the OAuth auth gate instead.
HERMES_DASHBOARD_INSECURE=true
# Container user — match a host UID to read hermes-data from outside.
HERMES_UID=10000
HERMES_GID=10000
# Host port for the Hermes API in the localhost source variant. Consumed by HERMES_ENDPOINT (in-container clients call this). Mirror of HERMES_API_PORT but for host-side Hermes processes.
HERMES_LOCALHOST_PORT=63028
# Host port for the Hermes web dashboard in the localhost source variant. The Kong route fronting hermes.localhost targets this. Mirror of HERMES_DASHBOARD_PORT but for host-side Hermes processes. The wizard's inline textbox edits HERMES_LOCALHOST_PORT (the API); override this via .env hand-edit if your host dashboard runs on a non-default port.
HERMES_LOCALHOST_DASHBOARD_PORT=63029
# Auto-managed by hermes. Container/disabled.
HERMES_INIT_SOURCE=container
# (auto-managed)
HERMES_INIT_SCALE=
# (auto-managed)
HERMES_SCALE=
# Resolved per HERMES_SOURCE. Consumed by openclaw-gateway, LiteLLM model_list.
# (auto-managed)
HERMES_ENDPOINT=
# (auto-managed)
TTS_INTERNAL_URL=
# (auto-managed)
STT_INTERNAL_URL=
# (auto-managed)
COMFYUI_INTERNAL_URL=
# (auto-managed)
SEARXNG_INTERNAL_URL=
# (auto-managed)
LIGHTRAG_INTERNAL_URL=

# ──────────────────────────────────────────────────────────────────────────
# apps: JupyterHub (DS/ML + LLM notebooks)  (services/jupyterhub/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | disabled
JUPYTERHUB_SOURCE=container

# Image references
JUPYTERHUB_IMAGE=quay.io/jupyter/datascience-notebook:python-3.11.10

JUPYTERHUB_PORT=63081
# Optional. Empty = generate on start.
# (secret)
JUPYTERHUB_TOKEN=
# Allowed browser origin for Jupyter Server websocket upgrades; keep '*' for local dev, narrow for shared deployments.
JUPYTER_ALLOW_ORIGIN=*
# Spark Connect endpoint used by bundled notebooks; override for a remote or managed Spark Connect server.
SPARK_REMOTE=sc://spark-connect:15002
# (auto-managed)
JUPYTERHUB_SCALE=

# ──────────────────────────────────────────────────────────────────────────
# infra: Kong (API gateway)  (services/kong/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
KONG_API_GATEWAY_IMAGE=kong:3.9.3

# Single-option (container only).
KONG_API_GATEWAY_SOURCE=container
KONG_HTTP_PORT=63000
KONG_HTTPS_PORT=63001
DASHBOARD_USERNAME=kong_admin
# Auto-generated on first ./start.sh when left at the placeholder (rotate-when-absent, like MINIO_ROOT_PASSWORD). Gates the Kong-routed Studio dashboard via basic-auth.
# (secret)
DASHBOARD_PASSWORD=kong_password

# ──────────────────────────────────────────────────────────────────────────
# agents: LightRAG (graph-augmented RAG server)  (services/lightrag/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | localhost | disabled
LIGHTRAG_SOURCE=disabled

# Image references
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:v1.5.4
LIGHTRAG_INIT_IMAGE=alpine:3.24.1

# Host port for LightRAG (in-container 9621).
LIGHTRAG_API_PORT=63063
# Host port for the localhost source variant.
LIGHTRAG_LOCALHOST_PORT=63068
# Auto-generated bearer key. Forwarded to LiteLLM as the model api_key.
# (secret)
LIGHTRAG_API_KEY=
# Auto-generated JWT signing key for LightRAG's /login endpoint. Without this, LightRAG falls back to a hardcoded default key (security risk).
# (secret)
LIGHTRAG_TOKEN_SECRET=
LIGHTRAG_WORKERS=2
LIGHTRAG_MEMORY_LIMIT=6g
LIGHTRAG_CPU_LIMIT=2.0
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_BINDING_HOST=http://litellm:4000/v1
# Empty = lightrag-init resolves from LITELLM_DEFAULT_MODEL.
LIGHTRAG_LLM_MODEL=
# Optional LightRAG EXTRACT role model. Empty = inherit LLM_MODEL.
LIGHTRAG_EXTRACT_LLM_MODEL=
# Optional LightRAG KEYWORD role model. Empty = inherit LLM_MODEL.
LIGHTRAG_KEYWORD_LLM_MODEL=
# Optional LightRAG QUERY role model. Empty = inherit LLM_MODEL.
LIGHTRAG_QUERY_LLM_MODEL=
# Optional EXTRACT role provider binding. Empty = inherit LLM_BINDING.
LIGHTRAG_EXTRACT_LLM_BINDING=
# Optional KEYWORD role provider binding. Empty = inherit LLM_BINDING.
LIGHTRAG_KEYWORD_LLM_BINDING=
# Optional QUERY role provider binding. Empty = inherit LLM_BINDING.
LIGHTRAG_QUERY_LLM_BINDING=
# Optional EXTRACT role provider endpoint. Empty = inherit LLM_BINDING_HOST.
LIGHTRAG_EXTRACT_LLM_BINDING_HOST=
# Optional KEYWORD role provider endpoint. Empty = inherit LLM_BINDING_HOST.
LIGHTRAG_KEYWORD_LLM_BINDING_HOST=
# Optional QUERY role provider endpoint. Empty = inherit LLM_BINDING_HOST.
LIGHTRAG_QUERY_LLM_BINDING_HOST=
# Optional EXTRACT role provider API key. Empty = inherit LLM_BINDING_API_KEY for same-provider roles.
# (secret)
LIGHTRAG_EXTRACT_LLM_BINDING_API_KEY=
# Optional KEYWORD role provider API key. Empty = inherit LLM_BINDING_API_KEY for same-provider roles.
# (secret)
LIGHTRAG_KEYWORD_LLM_BINDING_API_KEY=
# Optional QUERY role provider API key. Empty = inherit LLM_BINDING_API_KEY for same-provider roles.
# (secret)
LIGHTRAG_QUERY_LLM_BINDING_API_KEY=
# Optional EXTRACT role LLM concurrency. Empty = inherit MAX_ASYNC_LLM.
LIGHTRAG_EXTRACT_MAX_ASYNC_LLM=
# Optional KEYWORD role LLM concurrency. Empty = inherit MAX_ASYNC_LLM.
LIGHTRAG_KEYWORD_MAX_ASYNC_LLM=
# Optional QUERY role LLM concurrency. Empty = inherit MAX_ASYNC_LLM.
LIGHTRAG_QUERY_MAX_ASYNC_LLM=
# Optional EXTRACT role LLM timeout in seconds. Empty = inherit LLM_TIMEOUT.
LIGHTRAG_EXTRACT_LLM_TIMEOUT=
# Optional KEYWORD role LLM timeout in seconds. Empty = inherit LLM_TIMEOUT.
LIGHTRAG_KEYWORD_LLM_TIMEOUT=
# Optional QUERY role LLM timeout in seconds. Empty = inherit LLM_TIMEOUT.
LIGHTRAG_QUERY_LLM_TIMEOUT=
# LightRAG query default for reranking. Atlas keeps this false by default because direct LightRAG→TEI rerank payloads are incompatible without an adapter.
LIGHTRAG_QUERY_ENABLE_RERANK=false
# LightRAG query TOP_K. Atlas defaults this to a concrete integer because LightRAG v1.5.4 crashes when this env var is present but empty.
LIGHTRAG_QUERY_TOP_K=10
# LightRAG query CHUNK_TOP_K. Atlas defaults this to a concrete integer because LightRAG v1.5.4 crashes when this env var is present but empty.
LIGHTRAG_QUERY_CHUNK_TOP_K=5
# LightRAG query MAX_TOTAL_TOKENS. Atlas defaults this to a concrete integer because LightRAG v1.5.4 crashes when this env var is present but empty.
LIGHTRAG_QUERY_MAX_TOTAL_TOKENS=12000
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_BINDING_HOST=http://litellm:4000/v1
# Empty = lightrag-init resolves from LITELLM_EMBEDDING_MODEL.
LIGHTRAG_EMBEDDING_MODEL=
# Empty = auto (lightrag-init probes the embedding model's true dimension). Set ONLY to force a value — a wrong dim writes a mismatched PGVector index and every insert fails.
LIGHTRAG_EMBEDDING_DIM=
LIGHTRAG_VLM_PROCESS_ENABLE=true
LIGHTRAG_KV_STORAGE=RedisKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_DOC_STATUS_STORAGE=RedisDocStatusStorage
# (auto-managed)
LIGHTRAG_SCALE=
# (auto-managed)
LIGHTRAG_INIT_SCALE=
