# ============================================
# GenAI Vanilla Stack - Environment Variables
# ============================================
# Template configuration file - edit this file with your desired configuration.
# The start.sh script automatically copies this to .env when needed.
#
# Conventions
# -----------
# Every variable below lives in the section that owns its concept.
# Variables are one of two kinds:
#   • User-editable settings — SOURCE selectors, image tags, ports,
#     credentials, feature flags. Edit freely.
#   • AUTO-MANAGED runtime values — rewritten by ``./start.sh`` on every
#     run (bootstrapper/services/service_config.py). Hand-edits don't
#     stick. Listed here so the full inventory of variables the stack
#     reads is visible in one place, not lumped at the bottom of .env
#     on first launch. Each is tagged ``# AUTO-MANAGED``.
#
# ============================================
# COMMON SOURCE CONFIGURATIONS
# ============================================
# Edit the SOURCE variables below to configure your deployment:
#
# LOCALHOST SETUP (using local Ollama + ComfyUI):
#    LLM_PROVIDER_SOURCE=ollama-localhost
#    COMFYUI_SOURCE=localhost
#    All other services will run in containers
#
# FULL CONTAINER SETUP (everything in Docker):
#    LLM_PROVIDER_SOURCE=ollama-container-cpu
#    COMFYUI_SOURCE=container-cpu
#    All services run in containers (default)
#
# GPU CONTAINER SETUP (for production):
#    LLM_PROVIDER_SOURCE=ollama-container-gpu
#    COMFYUI_SOURCE=container-gpu
#    GPU-accelerated services in containers
#
# CLOUD-ONLY SETUP (no local Ollama, route everything through cloud providers):
#    LLM_PROVIDER_SOURCE=none
#    Set CLOUD_OPENAI_SOURCE / CLOUD_ANTHROPIC_SOURCE / CLOUD_OPENROUTER_SOURCE
#    to "enabled" and provide the matching OPENAI_API_KEY / ANTHROPIC_API_KEY /
#    OPENROUTER_API_KEY. The wizard collects these interactively; you can also
#    pass --openai-api-key / --anthropic-api-key / --openrouter-api-key on the
#    command line. Cloud keys live only in this .env file (never the DB) and
#    are read by the LiteLLM gateway, which fronts every other consumer.
#
# ============================================
# Global Configuration
# ============================================
PROJECT_NAME=genai

# Base port for the stack. All service ports derive from this by fixed offsets.
# You can edit this manually or run ./start.sh --base-port <port> to update it.
BASE_PORT=63000

# AUTO-MANAGED — container-runtime detection result. ``host-gateway`` on
# Docker; an IP literal on Podman (which does not understand the
# host-gateway alias). Emitted by ``bootstrapper/start.py`` during
# startup; consumed by every service's ``extra_hosts: host.docker.internal:${HOST_GATEWAY_IP}``.
HOST_GATEWAY_IP=host-gateway

# --------------------------------------------
# TUI Brand metadata (shown on the bootstrapper's pinned info-box and the
# Textual log app). All optional — empty values fall back to the defaults
# encoded in `bootstrapper/ui/state.py::AppState`. Override these if you
# fork this project and want the wizard to wear your fork's identity.
# --------------------------------------------
BRAND_NAME=GenAI Vanilla
BRAND_TAGLINE=AI Development Suite
BRAND_VERSION=
BRAND_AUTHOR=Kaveh Razavi
BRAND_LICENSE=Apache License 2.0
BRAND_REPO_URL=github.com/thekaveh/genai-vanilla

# ============================================
# CORE INFRASTRUCTURE SERVICES
# ============================================

# --------------------------------------------
# Supabase Database (supabase-db)
# --------------------------------------------
SUPABASE_DB_SOURCE=container  # Options: container
SUPABASE_DB_IMAGE=supabase/postgres:17.4.1.016
SUPABASE_DB_PORT=63000
# IMPORTANT: Must be 'supabase_admin' - required by Supabase base image
SUPABASE_DB_USER=supabase_admin
SUPABASE_DB_PASSWORD=password
SUPABASE_DB_NAME=postgres
# Additional DB users for applications
SUPABASE_DB_APP_USER=app_user
SUPABASE_DB_APP_PASSWORD=app_password

# --------------------------------------------
# Redis Cache (redis)
# --------------------------------------------
REDIS_SOURCE=container  # Options: container
REDIS_IMAGE=redis:7.2-alpine
REDIS_PORT=63001
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# --------------------------------------------
# Supabase DB Init (supabase-db-init)
# --------------------------------------------
SUPABASE_DB_INIT_SOURCE=container  # Options: container, disabled (auto-managed by supabase-db)
SUPABASE_DB_INIT_IMAGE=postgres:15-alpine

# --------------------------------------------
# Supabase Meta (supabase-meta)
# --------------------------------------------
SUPABASE_META_SOURCE=container  # Options: container, disabled
SUPABASE_META_IMAGE=supabase/postgres-meta:v0.88.9
SUPABASE_META_PORT=63004

# --------------------------------------------
# Supabase Storage (supabase-storage)
# --------------------------------------------
SUPABASE_STORAGE_SOURCE=container  # Options: container, disabled
SUPABASE_STORAGE_IMAGE=supabase/storage-api:v1.22.7
SUPABASE_STORAGE_PORT=63005
STORAGE_REGION=local
STORAGE_FILE_SIZE_LIMIT=52428800
STORAGE_BACKEND=file
PROJECT_REF=default
TENANT_ID=stub

# --------------------------------------------
# Supabase Auth (supabase-auth)
# --------------------------------------------
SUPABASE_AUTH_SOURCE=container  # Options: container, disabled
SUPABASE_AUTH_IMAGE=supabase/gotrue:v2.171.0
SUPABASE_AUTH_PORT=63006
# IMPORTANT: Run ./generate_supabase_keys.sh to generate these securely
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --------------------------------------------
# Supabase API/PostgREST (supabase-api)
# --------------------------------------------
SUPABASE_API_SOURCE=container  # Options: container, disabled
SUPABASE_API_IMAGE=postgrest/postgrest:v12.2.10
SUPABASE_API_PORT=63007

# --------------------------------------------
# Supabase Realtime (supabase-realtime)
# --------------------------------------------
SUPABASE_REALTIME_SOURCE=container  # Options: container, disabled
SUPABASE_REALTIME_IMAGE=supabase/realtime:v2.33.72
SUPABASE_REALTIME_PORT=63008

# --------------------------------------------
# Neo4j Graph Database (neo4j-graph-db)
# --------------------------------------------
NEO4J_GRAPH_DB_SOURCE=container  # Options: container, localhost, disabled
NEO4J_GRAPH_DB_IMAGE=neo4j:5.19.0
GRAPH_DB_HOST=graph-db
GRAPH_DB_PORT=63010
GRAPH_DB_DASHBOARD_PORT=63011
GRAPH_DB_USER=neo4j
GRAPH_DB_PASSWORD=neo4j_password
GRAPH_DB_AUTH=neo4j/neo4j_password  # Neo4j format: username/password
# AUTO-MANAGED — bolt URI consumers (backend, n8n) read at startup.
NEO4J_URI=bolt://neo4j-graph-db:7687
# AUTO-MANAGED — replica count; 0 when NEO4J_GRAPH_DB_SOURCE=disabled.
NEO4J_SCALE=1

# ============================================
# AI AND ML SERVICES
# ============================================

# --------------------------------------------
# LiteLLM Gateway (mandatory core service)
# --------------------------------------------
# LiteLLM is the always-on OpenAI-compatible front door for every LLM provider.
# Every consumer (Backend, Open WebUI, n8n, JupyterHub, Local Deep Researcher,
# Weaviate, OpenClaw) reads LITELLM_BASE_URL and LITELLM_API_KEY only.
LITELLM_SOURCE=container       # Locked: LiteLLM is mandatory; only one source value supported.
LITELLM_PORT=63012
LITELLM_IMAGE=ghcr.io/berriai/litellm:v1.83.14-stable.patch.2
LITELLM_INIT_SCALE=1
# Auto-generated by the bootstrapper on first start; never overwritten.
LITELLM_MASTER_KEY=
LITELLM_DB_NAME=litellm
LITELLM_EMBEDDING_MODEL=ollama/nomic-embed-text
# Optional override for the default chat model used by the backend's memory
# extraction service. When unset, the backend falls back to the highest-
# priority active content row in public.llms — Ollama rows are exposed as
# `ollama/<name>`; cloud rows use their LiteLLM model_name directly (bare
# `gpt-5`, `claude-sonnet-4-6`, `openrouter/<vendor>/<name>`, etc., per
# litellm-init's per-provider routing rules in
# litellm-init/scripts/init.py:render_model_list). Set this to e.g.
# `gpt-4o-mini` to pin extraction to a cloud model.
LITELLM_DEFAULT_MODEL=
# AUTO-MANAGED — derived from LLM_PROVIDER_SOURCE on every ./start.sh by
# bootstrapper/services/service_config.py::_generate_llm_provider_config.
# Hand-edits are overwritten. To point at a remote Ollama, set
# LLM_PROVIDER_SOURCE=ollama-external + LLM_PROVIDER_EXTERNAL_URL below.
# Resolved values per source:
#   ollama-container-*  → http://ollama:11434      (in-stack container)
#   ollama-localhost    → http://host.docker.internal:11434
#   ollama-external     → ${LLM_PROVIDER_EXTERNAL_URL}
#   none                → "" (LiteLLM has no Ollama upstream; cloud only)
# Empty IS honored — docker-compose.yml uses ``${VAR-default}`` (no
# colon) so the default fires only when the var is unset. An explicit
# empty value reaches the LiteLLM container as "" and disables Ollama
# routing.
# The default below is the placeholder a fresh checkout sees before the
# first ./start.sh; the next run rewrites it.
LITELLM_OLLAMA_UPSTREAM=http://ollama:11434
# AUTO-MANAGED — internal base URL every consumer reads. Stable across
# launches; the host port for human use lives at LITELLM_PORT above.
LITELLM_BASE_URL=http://litellm:4000

# --------------------------------------------
# LLM Engine — Ollama upstream the gateway forwards to
# --------------------------------------------
# Choose ONE local engine (mutually exclusive). Set to 'none' for cloud-only
# operation (requires at least one CLOUD_*_SOURCE=enabled below).
#   ollama-container-cpu  — Docker Ollama, CPU only (default)
#   ollama-container-gpu  — Docker Ollama with NVIDIA GPU
#   ollama-localhost      — Ollama running on the host machine (port 11434)
#   ollama-external       — remote Ollama at LLM_PROVIDER_EXTERNAL_URL
#   none                  — no local engine; cloud providers only
LLM_PROVIDER_SOURCE=ollama-container-cpu
LLM_PROVIDER_IMAGE=ollama/ollama:latest
LLM_PROVIDER_EXTERNAL_URL=  # Required when SOURCE=ollama-external
# AUTO-MANAGED — derived from LLM_PROVIDER_SOURCE. ``OLLAMA_SCALE=1`` for
# any ollama-container-*, 0 otherwise (localhost / external / none).
OLLAMA_SCALE=1
# AUTO-MANAGED — endpoint consumed by services that bypass LiteLLM
# (ollama-pull's direct /api/pull calls). Mirrors LITELLM_OLLAMA_UPSTREAM
# but exposed under a name backend / n8n recognise.
OLLAMA_ENDPOINT=http://ollama:11434
# AUTO-MANAGED — ``all`` when LLM_PROVIDER_SOURCE=ollama-container-gpu,
# ``null`` otherwise. Controls NVIDIA visibility for the Ollama container.
OLLAMA_NVIDIA_VISIBLE_DEVICES=null
# AUTO-MANAGED — Docker deploy.resources block (~ = unset; populated with
# GPU reservation when SOURCE=ollama-container-gpu).
OLLAMA_DEPLOY_RESOURCES=~

# --------------------------------------------
# Cloud LLM Providers (independent toggles)
# --------------------------------------------
# Each enabled provider must also have its API key set below. The bootstrapper
# refuses to start when LLM_PROVIDER_SOURCE=none AND every cloud source is disabled.
CLOUD_OPENAI_SOURCE=disabled       # Options: enabled, disabled
CLOUD_ANTHROPIC_SOURCE=disabled    # Options: enabled, disabled
CLOUD_OPENROUTER_SOURCE=disabled   # Options: enabled, disabled

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# AUTO-MANAGED — derived flags consumed by ``llm-catalog-init`` to gate
# which rows in public.llms get activated per provider. Rewritten on
# every ``./start.sh`` from the CLOUD_*_SOURCE values above by
# bootstrapper/services/service_config.py::_generate_cloud_providers_config.
LITELLM_OPENAI_ENABLED=false
LITELLM_ANTHROPIC_ENABLED=false
LITELLM_OPENROUTER_ENABLED=false
# AUTO-MANAGED — comma-separated lowercase list of enabled providers
# (e.g. "openai,openrouter"). Empty when every provider is disabled.
LITELLM_ENABLED_PROVIDERS=

# --------------------------------------------
# User-selected model lists (set by the wizard / CLI flags)
# --------------------------------------------
# Comma-separated model names that ``llm-catalog-init`` activates in
# public.llms on every ``docker compose up``. The wizard writes these
# from its multi-select prompts; CLI flags --openai-models /
# --anthropic-models / --openrouter-models / --ollama-models /
# --ollama-custom-models also feed them. Empty = preserve existing
# active rows; on a fresh DB with zero active cloud rows for a
# newly-enabled provider, llm-catalog-init activates the catalog's
# ``default_active`` set (see bootstrapper/utils/llm_catalog.py).
OPENAI_USER_MODELS=
ANTHROPIC_USER_MODELS=
OPENROUTER_USER_MODELS=
OLLAMA_USER_MODELS=
# Free-text additions — Ollama model names not in the curated catalog.
# Behaviour depends on LLM_PROVIDER_SOURCE:
#   • ollama-container-*  → ollama-pull fetches each one at startup.
#   • ollama-localhost / ollama-external → rows are registered in
#     public.llms for routing, but you must `ollama pull <name>` on
#     your host yourself (the in-stack puller never reaches a remote
#     daemon by design).
OLLAMA_CUSTOM_MODELS=

# --------------------------------------------
# Ollama Model Puller (ollama-pull)
# --------------------------------------------
# Bypasses LiteLLM by design — pulls models directly via Ollama's /api/pull.
# ollama-pull only runs when LLM_PROVIDER_SOURCE starts with ollama-container-*
# (no-op for ollama-localhost, ollama-external, none). Pull scaling is
# auto-managed by bootstrapper/services/service_config.py.
OLLAMA_PULL_IMAGE=alpine:latest
# AUTO-MANAGED — 1 only for ollama-container-* sources; 0 elsewhere.
OLLAMA_PULL_SCALE=1

# --------------------------------------------
# Weaviate Vector Database (weaviate)
# --------------------------------------------
WEAVIATE_SOURCE=container  # Options: container, localhost, disabled
WEAVIATE_IMAGE=cr.weaviate.io/semitechnologies/weaviate:1.27.5
WEAVIATE_PORT=63019
WEAVIATE_GRPC_PORT=63020
WEAVIATE_INIT_SOURCE=container  # Options: container, disabled (auto-managed by weaviate)
WEAVIATE_INIT_IMAGE=alpine:latest
MULTI2VEC_CLIP_SOURCE=container-cpu  # Options: container-cpu, container-gpu, disabled
MULTI2VEC_CLIP_IMAGE=semitechnologies/multi2vec-clip:sentence-transformers-clip-ViT-B-32
# Advanced Weaviate module controls. Defaults preserve the normal stack flow with
# multi2vec-clip enabled. If MULTI2VEC_CLIP_SOURCE=disabled, remove
# multi2vec-clip from WEAVIATE_ENABLE_MODULES and set CLIP_INFERENCE_API=.
WEAVIATE_ENABLE_MODULES=text2vec-openai,text2vec-ollama,multi2vec-clip,generative-openai,generative-ollama
CLIP_INFERENCE_API=http://multi2vec-clip:8080
# (Weaviate's text2vec-openai module reuses the cloud-provider OPENAI_API_KEY
# declared in the Cloud LLM Providers section above — but at runtime Weaviate
# connects to the LiteLLM gateway with LITELLM_MASTER_KEY, not to OpenAI directly.)
# AUTO-MANAGED — Weaviate's own URL exposed to consumers (backend, n8n).
WEAVIATE_URL=http://weaviate:8080
# AUTO-MANAGED — Ollama endpoint the text2vec-ollama / generative-ollama
# modules call directly (bypasses LiteLLM by design — module-level config).
WEAVIATE_OLLAMA_ENDPOINT=http://ollama:11434
# AUTO-MANAGED — LiteLLM gateway URL + key handed to text2vec-openai /
# generative-openai modules so they speak to LiteLLM, not OpenAI directly.
WEAVIATE_LITELLM_BASE_URL=http://litellm:4000/v1
WEAVIATE_LITELLM_API_KEY=
# AUTO-MANAGED — replica counts (0 when the corresponding SOURCE=disabled).
WEAVIATE_SCALE=1
WEAVIATE_INIT_SCALE=1
CLIP_SCALE=1
# AUTO-MANAGED — 1 only when MULTI2VEC_CLIP_SOURCE=container-gpu; 0 otherwise.
CLIP_ENABLE_CUDA=0
# AUTO-MANAGED — Docker deploy.resources for multi2vec-clip (~ = unset).
CLIP_DEPLOY_RESOURCES=~

# --------------------------------------------
# ComfyUI Init (comfyui-init)
# --------------------------------------------
COMFYUI_INIT_SOURCE=container  # Options: container, disabled (auto-managed by comfyui)
COMFYUI_INIT_IMAGE=alpine:latest
# AUTO-MANAGED — replica count.
COMFYUI_INIT_SCALE=1

# --------------------------------------------
# Local Deep Researcher (local-deep-researcher)
# --------------------------------------------
# NOTE: This is an adaptive service that automatically configures based on other services.
LOCAL_DEEP_RESEARCHER_SOURCE=container  # Options: container, disabled
LOCAL_DEEP_RESEARCHER_IMAGE=python:3.11-slim
LOCAL_DEEP_RESEARCHER_PORT=63013
LOCAL_DEEP_RESEARCHER_LOOPS=3
LOCAL_DEEP_RESEARCHER_SEARCH_API=searxng
LOCAL_DEEP_RESEARCHER_WORKERS=3
# AUTO-MANAGED — 0 when LOCAL_DEEP_RESEARCHER_SOURCE=disabled.
LOCAL_DEEP_RESEARCHER_SCALE=1

# --------------------------------------------
# SearxNG Search Engine (searxng)
# --------------------------------------------
SEARXNG_SOURCE=container  # Options: container, disabled
SEARXNG_IMAGE=searxng/searxng:latest
SEARXNG_PORT=63014
SEARXNG_SECRET=
SEARXNG_PUBLIC_INSTANCE=false
SEARXNG_ENABLE_METRICS=true
SEARXNG_DEFAULT_LOCALE=en
# AUTO-MANAGED — 0 when SEARXNG_SOURCE=disabled.
SEARXNG_SCALE=1

# --------------------------------------------
# n8n Workflow Automation (n8n)
# --------------------------------------------
N8N_SOURCE=container  # Options: container, disabled
N8N_IMAGE=n8nio/n8n:latest
N8N_PORT=63017
N8N_ENCRYPTION_KEY=your-random-encryption-key
N8N_AUTH_ENABLED=true
N8N_HOST=n8n.localhost
N8N_PROTOCOL=http
N8N_EXECUTIONS_MODE=queue
# Community packages support
N8N_COMMUNITY_PACKAGES_ENABLED=true
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true
# AUTO-MANAGED — main + worker replica counts.
N8N_SCALE=1
N8N_WORKER_SCALE=1

# --------------------------------------------
# n8n Init Service (n8n-init)
# --------------------------------------------
N8N_INIT_SOURCE=container  # Options: container, disabled (auto-managed by n8n)
N8N_INIT_IMAGE=alpine:latest
N8N_INIT_NODES=n8n-nodes-comfyui,@ksc1234/n8n-nodes-comfyui-image-to-image,n8n-nodes-mcp
# AUTO-MANAGED — replica count.
N8N_INIT_SCALE=1

# --------------------------------------------
# ComfyUI Image Generation (comfyui)
# --------------------------------------------
# For LOCALHOST SETUP: Set to 'localhost' to use local ComfyUI.
#    Default local app URL is COMFYUI_LOCALHOST_URL below; override it if your
#    installation uses another port, such as ComfyUI's common native 8188.
# For CONTAINER SETUP: Set to 'container-cpu' for Docker ComfyUI CPU (default)
# For GPU SETUP:       Set to 'container-gpu' for Docker ComfyUI with GPU acceleration
COMFYUI_SOURCE=container-cpu  # Options: container-cpu, container-gpu, localhost, external, disabled
COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui:v2-cpu-22.04-v0.2.7  # Use latest-cuda for GPU
COMFYUI_PORT=63018
COMFYUI_LOCALHOST_URL=http://host.docker.internal:8000  # Used when COMFYUI_SOURCE=localhost
COMFYUI_EXTERNAL_URL=  # Required when COMFYUI_SOURCE=external
COMFYUI_BASE_URL=http://comfyui:18188  # In-container default. Runtime value is computed from COMFYUI_SOURCE by the bootstrapper (see COMFYUI_ENDPOINT). Editing this line has no effect on the running stack.
COMFYUI_KONG_URL=http://kong-api-gateway:8000/comfyui
COMFYUI_ARGS=--listen
COMFYUI_AUTO_UPDATE=false
COMFYUI_PLATFORM=linux/amd64  # linux/amd64 for both CPU and GPU
# Storage Integration
COMFYUI_UPLOAD_TO_SUPABASE=true
COMFYUI_STORAGE_BUCKET=comfyui-images
# Model Management
COMFYUI_MODELS_PATH=/opt/ComfyUI/models
COMFYUI_OUTPUT_PATH=/opt/ComfyUI/output
COMFYUI_INPUT_PATH=/opt/ComfyUI/input
COMFYUI_CUSTOM_NODES_PATH=/opt/ComfyUI/custom_nodes
COMFYUI_LOCAL_MODELS_PATH=~/Documents/ComfyUI/models
# Model download configuration
COMFYUI_MODEL_SET=minimal  # Options: minimal (SD1.5 only), sd15 (SD1.5 + VAE), sdxl (SDXL + VAE), full (all models)
# AUTO-MANAGED — replica count (0 when SOURCE=localhost/external/disabled).
COMFYUI_SCALE=1
# AUTO-MANAGED — endpoint backend / n8n / Open WebUI talk to. Resolves to:
#   container-*   → http://comfyui:18188
#   localhost     → COMFYUI_LOCALHOST_URL
#   external      → COMFYUI_EXTERNAL_URL
COMFYUI_ENDPOINT=http://comfyui:18188
# AUTO-MANAGED — Docker deploy.resources block (GPU reservation when
# SOURCE=container-gpu; ~ otherwise).
COMFYUI_DEPLOY_RESOURCES=~
# AUTO-MANAGED — true when COMFYUI_SOURCE=localhost (consumed by
# integrations that need to know about host-side ComfyUI).
IS_LOCAL_COMFYUI=false

# --------------------------------------------
# STT Provider Service (stt-provider / parakeet)
# --------------------------------------------
# For LOCALHOST (Mac/Linux): Set to 'parakeet-localhost' and run STT natively on host
#    - Mac users: Use this for MLX/Metal GPU acceleration (Docker MLX not supported)
#    - Linux users: Use this with CPU or custom GPU setup
# For GPU (Docker):          Set to 'parakeet-container-gpu' for NVIDIA GPU in container
# For NO STT:                Set to 'disabled'
#
# NOTE: MLX requires native macOS execution and cannot run in Docker containers.
#       Mac users must use 'parakeet-localhost' option.
STT_PROVIDER_SOURCE=disabled  # Options: disabled, parakeet-localhost, parakeet-container-gpu

# Port Configuration (calculated: base_port + 22)
# Auto-updates when you run: ./start.sh --base-port XXXX
STT_PROVIDER_PORT=63022
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3  # or nvidia/parakeet-tdt-0.6b-v2 for English-only

# Service Scale (set by bootstrapper based on SOURCE)
PARAKEET_GPU_SCALE=0   # 1 when SOURCE=parakeet-container-gpu, 0 otherwise

# GPU-specific (for parakeet-container-gpu)
PARAKEET_GPU_DEVICE=cuda
PARAKEET_GPU_COMPUTE_TYPE=float16  # Options: float16, float32, int8
PARAKEET_GPU_IMAGE=nvcr.io/nvidia/pytorch:25.01-py3
NVIDIA_VISIBLE_DEVICES=all

# Localhost-specific (for parakeet-localhost)
PARAKEET_LOCALHOST_URL=http://host.docker.internal:63022

# Optional: Hugging Face token for private models
HUGGING_FACE_HUB_TOKEN=
# AUTO-MANAGED — endpoint exposed to Open WebUI / backend; empty when STT is disabled.
PARAKEET_ENDPOINT=

# --------------------------------------------
# TTS Provider Service (tts-provider / XTTS v2)
# --------------------------------------------
# For GPU (Docker):  Set to 'xtts-container-gpu' for NVIDIA GPU in container
# For LOCALHOST:     Set to 'xtts-localhost' and run TTS server natively
# For NO TTS:        Set to 'disabled' (default)
#
# NOTE: TTS is disabled by default to conserve resources
TTS_PROVIDER_SOURCE=disabled

# Port Configuration (calculated: base_port + 23)
# Auto-updates when you run: ./start.sh --base-port XXXX
TTS_PROVIDER_PORT=63023
XTTS_MODEL=tts-1-hd  # tts-1 (Piper/fast) or tts-1-hd (XTTS v2/quality)

# Service Scale (set by bootstrapper based on SOURCE)
XTTS_GPU_SCALE=0

# GPU-specific (for xtts-container-gpu)
XTTS_GPU_IMAGE=ghcr.io/matatonic/openedai-speech:latest
# NVIDIA_VISIBLE_DEVICES=all (already defined above in STT section)

# Localhost-specific (for xtts-localhost)
XTTS_LOCALHOST_URL=http://host.docker.internal:63023

# Optional: Hugging Face token for model downloads
# HUGGING_FACE_HUB_TOKEN= (already defined above)
# AUTO-MANAGED — endpoint exposed to Open WebUI / backend; empty when TTS is disabled.
XTTS_ENDPOINT=

# --------------------------------------------
# Document Processor Service (doc-processor / Docling)
# --------------------------------------------
# For GPU (Docker):       Set to 'docling-container-gpu' for NVIDIA GPU acceleration
# For LOCALHOST:          Set to 'docling-localhost' and run Docling server natively
# For NO DOC PROCESSING:  Set to 'disabled' (default)
#
# NOTE: Document processing is disabled by default to conserve resources.
#       Enable when you need PDF/DOCX/HTML parsing for RAG workflows.
#       GPU provides 4.3x speedup for table extraction vs CPU.
DOC_PROCESSOR_SOURCE=disabled  # Options: disabled, docling-container-gpu, docling-localhost

# Port Configuration (calculated: base_port + 21)
# Auto-updates when you run: ./start.sh --base-port XXXX
DOC_PROCESSOR_PORT=63021

# Service Scale (set by bootstrapper based on SOURCE - DO NOT MANUALLY EDIT)
DOCLING_GPU_SCALE=0   # 1 when SOURCE=docling-container-gpu, 0 otherwise

# Processing Configuration
DOCLING_OUTPUT_FORMAT=markdown  # Options: markdown, html, json, doctags
DOCLING_USE_OCR=auto  # Options: auto, always, never
DOCLING_TABLE_MODE=accurate  # Options: accurate (4.3x slower, better quality), fast

# GPU-specific (for docling-container-gpu)
DOCLING_GPU_DEVICE=cuda
DOCLING_GPU_IMAGE=pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime
# NVIDIA_VISIBLE_DEVICES=all (already defined above in STT section)

# Localhost-specific (for docling-localhost)
# NOTE: DOCLING_ENDPOINT is auto-calculated by bootstrapper:
#       http://host.docker.internal:${DOC_PROCESSOR_PORT}
#       This endpoint is provided to backend, n8n, and jupyterhub services.

# Optional: Hugging Face token for private/gated models
# HUGGING_FACE_HUB_TOKEN= (already defined above)

# Advanced Options
DOCLING_MAX_FILE_SIZE=52428800  # 50MB (matches Supabase Storage limit)
DOCLING_ENABLE_FORMULAS=true    # Extract LaTeX formulas
DOCLING_ENABLE_CODE_BLOCKS=true # Extract code blocks
DOCLING_CHUNK_SIZE=512          # Chunk size for RAG
DOCLING_CHUNK_OVERLAP=50        # Chunk overlap tokens
# AUTO-MANAGED — endpoint backend / n8n / jupyterhub read; empty when disabled.
DOCLING_ENDPOINT=

# --------------------------------------------
# OpenClaw AI Agent (openclaw-gateway)
# --------------------------------------------
# Open-source AI agent for messaging apps (WhatsApp, Telegram, Discord, etc.)
# Can manage files, calendars, monitor GitHub repos, execute commands
# Includes a web dashboard for administration
#
# For CONTAINER:    Set to 'container' to run OpenClaw gateway in Docker
# For LOCALHOST:    Set to 'localhost' and run OpenClaw natively on host
#    - Requires: Node.js 22+ and `npm install -g openclaw`
#    - Default stack expectation: `openclaw gateway --port 63024`
#    - If your local OpenClaw uses its native/default 18789, set:
#      OPENCLAW_LOCALHOST_URL=http://host.docker.internal:18789
# For NO OPENCLAW:  Set to 'disabled' (default)
#
# NOTE: OpenClaw is disabled by default to conserve resources.
#       Enable when you need AI agent connectivity to messaging platforms.
OPENCLAW_SOURCE=disabled  # Options: disabled, container, localhost

# Image Configuration
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Port Configuration (calculated: base_port + 24, base_port + 25)
# Auto-updates when you run: ./start.sh --base-port XXXX
OPENCLAW_GATEWAY_PORT=63024
OPENCLAW_BRIDGE_PORT=63025

# Service Scale (set by bootstrapper based on SOURCE - DO NOT MANUALLY EDIT)
OPENCLAW_SCALE=0  # 1 when SOURCE=container, 0 otherwise

# Gateway Token (optional: for securing the gateway HTTP API and web dashboard)
OPENCLAW_GATEWAY_TOKEN=

# LLM API Keys (optional: override stack-wide keys for OpenClaw specifically)
# If empty, OpenClaw routes through the LiteLLM gateway. Set these only when
# OpenClaw should call the cloud provider directly (bypassing LiteLLM).
# OPENCLAW_ANTHROPIC_API_KEY=
# OPENCLAW_OPENAI_API_KEY=

# Localhost-specific (for localhost mode)
OPENCLAW_LOCALHOST_URL=http://host.docker.internal:63024

# OpenClaw Init (auto-managed)
OPENCLAW_INIT_SOURCE=container  # Options: container, disabled (auto-managed by openclaw)
OPENCLAW_INIT_IMAGE=alpine:latest
# AUTO-MANAGED — replica count (0 when OPENCLAW_SOURCE=disabled/localhost).
OPENCLAW_INIT_SCALE=0
# AUTO-MANAGED — endpoint backend / n8n call; empty when disabled.
OPENCLAW_ENDPOINT=

# ============================================
# APPLICATION SERVICES
# ============================================
#
# NOTE: Some services in this section are "adaptive services" that automatically
# configure themselves based on other services (like LLM provider, ComfyUI, etc.).
# These adaptive services do not support SOURCE variations and always run as
# containers when enabled. They include: backend, open-web-ui, local-deep-researcher.

# --------------------------------------------
# Supabase Studio (supabase-studio)
# --------------------------------------------
SUPABASE_STUDIO_SOURCE=container  # Options: container, disabled
SUPABASE_STUDIO_IMAGE=supabase/studio:latest
SUPABASE_STUDIO_PORT=63009

# --------------------------------------------
# Kong API Gateway (kong-api-gateway)
# --------------------------------------------
KONG_API_GATEWAY_SOURCE=container  # Options: container
KONG_API_GATEWAY_IMAGE=kong:3.9.0
KONG_HTTP_PORT=63002
KONG_HTTPS_PORT=63003
DASHBOARD_USERNAME=kong_admin
DASHBOARD_PASSWORD=kong_password

# --------------------------------------------
# Open WebUI (open-web-ui)
# --------------------------------------------
# NOTE: This is an adaptive service that automatically configures based on other services.
OPEN_WEB_UI_SOURCE=container  # Options: container, disabled
OPEN_WEB_UI_IMAGE=dyrnq/open-webui:latest
OPEN_WEB_UI_PORT=63015
OPEN_WEB_UI_SECRET_KEY=secret
# Admin account (seeded by Open WebUI on first run from these env vars;
# docker-compose.yml falls back to admin@localhost / admin / Admin when
# any of these are unset, so a stack that's already been seeded keeps
# working even if you delete these lines. Re-seeding requires wiping
# the Open WebUI data volume.)
OPEN_WEB_UI_ADMIN_EMAIL=admin@localhost
OPEN_WEB_UI_ADMIN_PASSWORD=admin
OPEN_WEB_UI_ADMIN_NAME=Admin
# Redis WebSocket Integration
OPEN_WEB_UI_WEBSOCKET_SUPPORT=true
OPEN_WEB_UI_REDIS_DB=2
OPEN_WEB_UI_MODEL_CACHE_TTL=300
# AUTO-MANAGED — replica counts.
OPEN_WEB_UI_SCALE=1
OPEN_WEB_UI_INIT_SCALE=1
# AUTO-MANAGED — TTS/STT engine wiring. Populated when TTS_PROVIDER_SOURCE
# or STT_PROVIDER_SOURCE is enabled; empty (compose falls back to none)
# when the corresponding provider is disabled.
OPEN_WEB_UI_TTS_ENGINE=
OPEN_WEB_UI_STT_ENGINE=
OPEN_WEB_UI_TTS_API_URL=
OPEN_WEB_UI_STT_API_URL=

# --------------------------------------------
# Backend API Service (backend)
# --------------------------------------------
# NOTE: This is an always-on adaptive core service that automatically configures
# based on other services. It is currently not optional/disableable.
BACKEND_SOURCE=container  # Adaptive core service; always container
BACKEND_IMAGE=python:3.12
BACKEND_PORT=63016
# AUTO-MANAGED — replica count.
BACKEND_SCALE=1

# --------------------------------------------
# LangMem Memory Configuration
# --------------------------------------------
# Persistent conversation memory with automated fact extraction and retrieval.
# LangMem runs inside the Backend service (no separate container needed).
LANGMEM_ENABLED=true
LANGMEM_MEMORY_NAMESPACE=default
LANGMEM_AUTO_CONSOLIDATE=true
LANGMEM_CONSOLIDATION_INTERVAL=86400  # seconds between auto-consolidation runs (24h)
LANGMEM_MAX_FACTS_PER_USER=1000
LANGMEM_EXTRACTION_MODEL=  # LiteLLM model identifier for fact extraction (e.g. ollama/qwen3.6:latest); empty = pick highest-priority active content model from public.llms
LANGMEM_EMBEDDING_MODEL=   # Embedding model for pgvector fallback (empty = use stack default)

# --------------------------------------------
# JupyterHub Data Science IDE (jupyterhub)
# --------------------------------------------
# NOTE: This is an adaptive service that automatically configures based on other services.
JUPYTERHUB_SOURCE=container  # Options: container, disabled
# Using python-3.11 tag for stable builds and Docker cache optimization
# Note: :latest tag causes rebuilds every time. Use specific version for caching.
JUPYTERHUB_IMAGE=jupyter/datascience-notebook:python-3.11
JUPYTERHUB_PORT=63048
JUPYTERHUB_TOKEN=  # Optional: Set token for authentication (empty = generate on start)
# AUTO-MANAGED — replica count.
JUPYTERHUB_SCALE=1

# ============================================
# GPU RESOURCE CONFIGURATION
# ============================================
# Resource limits for GPU-enabled services
PROD_ENV_CPUS=2
PROD_ENV_MEM_LIMIT=8g
PROD_ENV_BACKEND_CPUS=1
PROD_ENV_BACKEND_MEM_LIMIT=2g
PROD_ENV_N8N_CPUS=1
PROD_ENV_N8N_MEM_LIMIT=2g
PROD_ENV_COMFYUI_CPUS=2
PROD_ENV_COMFYUI_MEM_LIMIT=4g

# =============================================================================
# MinIO (S3-compatible object storage — artifact-tier complement to Supabase Storage)
# =============================================================================
MINIO_SOURCE=container                            # Options: container, disabled
MINIO_IMAGE=minio/minio:RELEASE.2025-10-15T17-29-55Z
MINIO_INIT_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
MINIO_PORT=63026                                  # S3 API
MINIO_CONSOLE_PORT=63027                          # Admin console UI
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=                              # Auto-generated on first start
MINIO_REGION=us-east-1
MINIO_ENDPOINT=                                   # AUTO-MANAGED (internal, e.g. http://minio:9000)
MINIO_PUBLIC_ENDPOINT=                            # AUTO-MANAGED (host, e.g. http://localhost:63026)
MINIO_SCALE=1                                     # AUTO-MANAGED (0 when MINIO_SOURCE=disabled)

# Per-consumer bucket names + service-account credentials
MINIO_BUCKET_COMFYUI=comfyui
MINIO_COMFYUI_ACCESS_KEY=                         # Auto-generated on first start
MINIO_COMFYUI_SECRET_KEY=                         # Auto-generated on first start

MINIO_BUCKET_BACKEND=backend
MINIO_BACKEND_ACCESS_KEY=                         # Auto-generated on first start
MINIO_BACKEND_SECRET_KEY=                         # Auto-generated on first start

MINIO_BUCKET_N8N=n8n
MINIO_N8N_ACCESS_KEY=                             # Auto-generated on first start
MINIO_N8N_SECRET_KEY=                             # Auto-generated on first start

MINIO_BUCKET_JUPYTER=jupyter
MINIO_JUPYTER_ACCESS_KEY=                         # Auto-generated on first start
MINIO_JUPYTER_SECRET_KEY=                         # Auto-generated on first start

MINIO_BUCKET_DOCLING=docling
MINIO_DOCLING_ACCESS_KEY=                         # Auto-generated on first start
MINIO_DOCLING_SECRET_KEY=                         # Auto-generated on first start
