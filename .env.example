# ──────────────────────────────────────────────────────────────────────────
# data: Neo4j (graph database)  (services/neo4j/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | localhost | disabled
NEO4J_GRAPH_DB_SOURCE=container

# Image references
# Used as build-arg BASE_IMAGE in graph-db/Dockerfile.
NEO4J_GRAPH_DB_IMAGE=neo4j:5.19.0

# Internal hostname (only relevant for container source).
GRAPH_DB_HOST=graph-db
# Host port for Neo4j bolt (container port 7687).
GRAPH_DB_PORT=63020
# Host port for Neo4j browser dashboard (container port 7474).
GRAPH_DB_DASHBOARD_PORT=63021
GRAPH_DB_USER=neo4j
# (secret)
GRAPH_DB_PASSWORD=neo4j_password
# Neo4j auth in username/password format.
# (secret)
GRAPH_DB_AUTH=neo4j/neo4j_password
# Computed from NEO4J_GRAPH_DB_SOURCE. Read by backend/jupyterhub.
# (auto-managed)
NEO4J_URI=
# Replicas: 1 for container, 0 otherwise.
# (auto-managed)
NEO4J_SCALE=
# Host HTTP port for the neo4j-localhost source variant (browser UI + REST). Kong route target is derived as http://host.docker.internal:7474.
NEO4J_LOCALHOST_HTTP_PORT=7474
# Host Bolt port for the neo4j-localhost source variant (driver protocol). NEO4J_URI is derived as bolt://host.docker.internal:7687. The wizard's inline-textbox edits THIS port (HTTP is overridable via .env hand-edit).
NEO4J_LOCALHOST_BOLT_PORT=7687

# ──────────────────────────────────────────────────────────────────────────
# llm: Ollama (local LLM engine)  (services/ollama/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: ollama-container-cpu | ollama-container-gpu | ollama-localhost | none
LLM_PROVIDER_SOURCE=ollama-container-cpu

# Image references
LLM_PROVIDER_IMAGE=ollama/ollama:latest
OLLAMA_PULL_IMAGE=alpine:latest

# Comma-separated Ollama model names the wizard activated.
OLLAMA_USER_MODELS=
# Free-text extra Ollama models pulled in container-* sources.
OLLAMA_CUSTOM_MODELS=
# When LLM_PROVIDER_SOURCE=ollama-localhost, llm-catalog-init queries the upstream's /api/tags and auto-imports every model found, unioning with OLLAMA_USER_MODELS. Set false to keep strict wizard-only control.
OLLAMA_AUTO_IMPORT_LOCAL_MODELS=true
# Reserved for future GPU deploy block. Currently '~' (null).
OLLAMA_DEPLOY_RESOURCES=~
# (auto-managed)
OLLAMA_SCALE=
# (auto-managed)
OLLAMA_PULL_SCALE=
# (auto-managed)
OLLAMA_NVIDIA_VISIBLE_DEVICES=
# (auto-managed)
OLLAMA_ENDPOINT=
# Ollama URL the LiteLLM gateway forwards Ollama-routed requests to. Owned by ollama because the value flips with LLM_PROVIDER_SOURCE; consumed by litellm-init when rendering its config.yaml.
# (auto-managed)
LITELLM_OLLAMA_UPSTREAM=
# Host port for the ollama-localhost source variant. URL is derived at compose-render time as http://host.docker.internal:11434.
OLLAMA_LOCALHOST_PORT=11434

