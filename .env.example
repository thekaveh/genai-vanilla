# Auto-managed by supabase-db. Container/disabled.
SUPABASE_DB_INIT_SOURCE=container
# Host port for postgres-exporter (in-container 9187). Sidecar gated by PROMETHEUS_SOURCE.
POSTGRES_EXPORTER_PORT=63011
# Set by _generate_prometheus_config() to 1 when PROMETHEUS_SOURCE=container, 0 otherwise.
# (auto-managed)
POSTGRES_EXPORTER_SCALE=
SUPABASE_META_SOURCE=container
SUPABASE_META_PORT=63012
SUPABASE_STORAGE_SOURCE=container
SUPABASE_STORAGE_PORT=63013
STORAGE_REGION=local
STORAGE_FILE_SIZE_LIMIT=52428800
STORAGE_BACKEND=file
PROJECT_REF=default
TENANT_ID=stub
SUPABASE_AUTH_SOURCE=container
SUPABASE_AUTH_PORT=63014
# Auto-generated by bootstrapper/generate_supabase_keys.py on first run.
# (secret)
SUPABASE_JWT_SECRET=
# Auto-generated.
# (secret)
SUPABASE_ANON_KEY=
# Auto-generated.
# (secret)
SUPABASE_SERVICE_KEY=
SUPABASE_API_SOURCE=container
SUPABASE_API_PORT=63015
SUPABASE_REALTIME_SOURCE=container
SUPABASE_REALTIME_PORT=63016
SUPABASE_STUDIO_SOURCE=container
SUPABASE_STUDIO_PORT=63017

# ──────────────────────────────────────────────────────────────────────────
# llm: TEI Reranker (mxbai-rerank-base-v1)  (services/tei-reranker/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container-cpu | container-gpu | localhost | disabled
TEI_RERANKER_SOURCE=disabled

# Image references
# Used when TEI_RERANKER_SOURCE=container-cpu on amd64 hosts. Compiled with ORT backend (requires ONNX model weights).
TEI_RERANKER_CPU_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.9
# Used when TEI_RERANKER_SOURCE=container-cpu on arm64 hosts (Apple Silicon). Compiled with candle backend (loads safetensors natively, no ONNX required). Unversioned tag — HF doesn't publish versioned arm64 tags as of 2026-06-06.
TEI_RERANKER_CPU_ARM64_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-arm64-latest
# Used when TEI_RERANKER_SOURCE=container-gpu. CUDA host required.
TEI_RERANKER_GPU_IMAGE=ghcr.io/huggingface/text-embeddings-inference:1.9

# Host port for the TEI rerank API (in-container listen port is 80).
TEI_RERANKER_PORT=63031
# Host port for the host-installed TEI rerank source variant.
TEI_RERANKER_LOCALHOST_PORT=63031
TEI_RERANKER_MODEL_ID=mixedbread-ai/mxbai-rerank-base-v1
TEI_RERANKER_REVISION=main
TEI_RERANKER_MAX_CLIENT_BATCH_SIZE=32
TEI_RERANKER_MEMORY_LIMIT=4g
TEI_RERANKER_CPU_LIMIT=2.0
TEI_RERANKER_HF_CACHE_DIR=/data
# (auto-managed)
TEI_RERANKER_SCALE=
# Resolved per TEI_RERANKER_SOURCE. Exposes TEI's rerank endpoint to compatible consumers.
# (auto-managed)
TEI_RERANKER_ENDPOINT=
# Image picked per source variant (CPU vs GPU).
# (auto-managed)
TEI_RERANKER_IMAGE_RESOLVED=

# ──────────────────────────────────────────────────────────────────────────
# media: TTS provider (text-to-speech engine selector)  (services/tts-provider/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: speaches-container-cpu | speaches-container-gpu | chatterbox-container-gpu | chatterbox-localhost | disabled
TTS_PROVIDER_SOURCE=speaches-container-cpu

# Wizard display slot. Real engine port lives on its own container manifest.
TTS_PROVIDER_PORT=63044
# Aggregate scale across all TTS engines. Reserved for future use.
# (auto-managed)
TTS_PROVIDER_SCALE=
# Resolved per TTS_PROVIDER_SOURCE. Consumed by n8n, backend, jupyterhub, open-webui, hermes-init (as TTS_INTERNAL_URL — owned by services/hermes/).
# (auto-managed)
TTS_ENDPOINT=

# ──────────────────────────────────────────────────────────────────────────
# data: Weaviate (vector database)  (services/weaviate/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | localhost | disabled
WEAVIATE_SOURCE=container

# Image references
WEAVIATE_IMAGE=cr.weaviate.io/semitechnologies/weaviate:1.38.2
WEAVIATE_INIT_IMAGE=alpine:3.24.1
MULTI2VEC_CLIP_IMAGE=semitechnologies/multi2vec-clip:sentence-transformers-clip-ViT-B-32-1.5.1

WEAVIATE_PORT=63026
WEAVIATE_GRPC_PORT=63027
# Auto-managed by weaviate. Container/disabled.
WEAVIATE_INIT_SOURCE=container
# Options: container-cpu, container-gpu, disabled. (Effects driven by hook.)
MULTI2VEC_CLIP_SOURCE=container-cpu
WEAVIATE_ENABLE_MODULES=text2vec-openai,text2vec-ollama,multi2vec-clip,generative-openai,generative-ollama
CLIP_INFERENCE_API=http://multi2vec-clip:8080
# Resolved per WEAVIATE_SOURCE. Consumed by n8n, backend, jupyterhub.
# (auto-managed)
WEAVIATE_URL=
# Mirror of LITELLM_MASTER_KEY for Weaviate's vectorizer auth.
# (auto-managed, secret)
WEAVIATE_LITELLM_API_KEY=
# (auto-managed)
WEAVIATE_SCALE=
# (auto-managed)
WEAVIATE_INIT_SCALE=
# Computed from MULTI2VEC_CLIP_SOURCE.
# (auto-managed)
CLIP_SCALE=
# (auto-managed)
CLIP_ENABLE_CUDA=
CLIP_DEPLOY_RESOURCES=~
# Host port for the weaviate-localhost source variant. URL is derived at compose-render time as http://host.docker.internal:8080.
WEAVIATE_LOCALHOST_PORT=8080
# Container memory limit for the weaviate container (deploy.resources.limits.memory). 2 g is conservative for a 32 GB host; the Go-based Weaviate data plane plus in-memory HNSW index fits comfortably for small-to-medium collections.
WEAVIATE_MEMORY_LIMIT=2g
# Container CPU limit for the weaviate container (deploy.resources.limits.cpus). 1.5 cores covers routine indexing and query serving on a shared host.
WEAVIATE_CPU_LIMIT=1.5

# ──────────────────────────────────────────────────────────────────────────
# apps: Apache Zeppelin (Spark-first notebook)  (services/zeppelin/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | disabled
ZEPPELIN_SOURCE=disabled

# Image references
ZEPPELIN_IMAGE=apache/zeppelin:0.12.1

# Host port for the Zeppelin Web UI (in-container 8080).
ZEPPELIN_PORT=63084
# (auto-managed)
ZEPPELIN_SCALE=
# Container memory limit for the zeppelin container (deploy.resources.limits.memory). Zeppelin's JVM-based interpreter host typically uses under 1 g for a single-user session; 2 g leaves comfortable headroom on a 32 GB host.
ZEPPELIN_MEMORY_LIMIT=2g
# Container CPU limit for the zeppelin container (deploy.resources.limits.cpus). 1.5 cores covers notebook rendering and interpreter dispatch; compute-heavy work runs on the remote Spark cluster, not in this process.
ZEPPELIN_CPU_LIMIT=1.5
