# ──────────────────────────────────────────────────────────────────────────
# infra: Cloudflare Tunnel (public edge)  (services/cloudflared/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | disabled
CLOUDFLARED_SOURCE=disabled

# Image references
# Cloudflare Tunnel daemon. Pin a dated tag; bump deliberately.
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.6.1

# Cloudflare named-tunnel token (Zero Trust > Networks > Tunnels). When
# CLOUDFLARED_SOURCE=container this must be set or the daemon exits. The
# tunnel's public hostname is configured in the Cloudflare dashboard to
# point at http://kong-api-gateway:8000.
# (secret)
CLOUDFLARE_TUNNEL_TOKEN=
# Set to 1 when CLOUDFLARED_SOURCE=container, 0 when disabled.
# (auto-managed)
CLOUDFLARED_SCALE=

# ──────────────────────────────────────────────────────────────────────────
# media: ComfyUI (image generation)  (services/comfyui/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container-cpu | container-gpu | localhost | disabled
COMFYUI_SOURCE=container-cpu

# Image references
# Use latest-cuda for GPU.
COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui:v2-cpu-22.04-v0.2.7
COMFYUI_INIT_IMAGE=alpine:3.24.1

COMFYUI_INIT_SOURCE=container
COMFYUI_PORT=63041
# Host port for the localhost source variant. URL is derived at compose-render time as http://host.docker.internal:8000.
COMFYUI_LOCALHOST_PORT=8000
# In-container default. Runtime value is COMFYUI_ENDPOINT computed by hook.
COMFYUI_BASE_URL=http://comfyui:18188
COMFYUI_KONG_URL=http://kong-api-gateway:8000/comfyui
COMFYUI_ARGS=--listen
COMFYUI_AUTO_UPDATE=false
COMFYUI_PLATFORM=linux/amd64
COMFYUI_UPLOAD_TO_SUPABASE=true
COMFYUI_STORAGE_BUCKET=comfyui-images
COMFYUI_MODELS_PATH=/opt/ComfyUI/models
COMFYUI_LOCAL_MODELS_PATH=~/Documents/ComfyUI/models
# Comma-separated catalog model names the user picked in the wizard (or via --comfyui-models). Read by services/comfyui/init/scripts/download_models.sh.
COMFYUI_USER_MODELS=
# Path to the ComfyUI custom-models sidecar YAML (user-authored models not in the curated catalog). Read by comfyui_resolver when generating the download manifest, and by the wizard's model picker.
COMFYUI_CUSTOM_MODELS_FILE=/custom-models.yaml
# (auto-managed)
COMFYUI_INIT_SCALE=
# (auto-managed)
COMFYUI_SCALE=
# Resolved per COMFYUI_SOURCE. Consumed by backend, open-webui, n8n, jupyterhub.
# (auto-managed)
COMFYUI_ENDPOINT=
COMFYUI_DEPLOY_RESOURCES=~
# Container memory limit for the comfyui container (deploy.resources.limits.memory). 4 g is appropriate for CPU-only inference; GPU workloads holding VRAM are bounded by device memory, not host RAM, so 4 g is still a safe OOM fence on a 32 GB host.
COMFYUI_MEMORY_LIMIT=4g
# Container CPU limit for the comfyui container (deploy.resources.limits.cpus). 2.0 cores keeps CPU-mode inference from monopolising the host; GPU mode is GPU-bound so the CPU cap is irrelevant in practice.
COMFYUI_CPU_LIMIT=2.0

# ──────────────────────────────────────────────────────────────────────────
