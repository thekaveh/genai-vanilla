# ============================================================================
# GENERATED FILE — DO NOT EDIT BY HAND
#
# This .env.example is produced by bootstrapper/services/env_assembler.py
# from services/<name>/service.yml manifests. To change a default, edit the
# relevant manifest and re-run `./start.sh` (which regenerates this file)
# or `python -m services.env_assembler` for the regen-only path.
#
# Variables flagged `auto-managed` are computed at runtime by the bootstrapper
# from SOURCE values and are intentionally emitted without a default here.
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────
# apps: Backend API (FastAPI)  (services/backend/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
BACKEND_IMAGE=python:3.12

# Adaptive core service; always container. Single-option.
BACKEND_SOURCE=container
BACKEND_PORT=63080
# Always 1 (BACKEND_SOURCE is single-valued).
# (auto-managed)
BACKEND_SCALE=
LANGMEM_ENABLED=true
LANGMEM_MEMORY_NAMESPACE=default
LANGMEM_AUTO_CONSOLIDATE=true
LANGMEM_CONSOLIDATION_INTERVAL=86400
LANGMEM_MAX_FACTS_PER_USER=1000
# LiteLLM model id (empty = highest-priority active content model from public.llms).
LANGMEM_EXTRACTION_MODEL=
LANGMEM_EMBEDDING_MODEL=

# ──────────────────────────────────────────────────────────────────────────
# media: Chatterbox (voice-cloning TTS, GPU)  (services/chatterbox/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
# Rolling :gpu tag. Pin to a digest in production via `docker pull travisvn/chatterbox-tts-api:gpu` + paste the digest.
CHATTERBOX_IMAGE=travisvn/chatterbox-tts-api:gpu

# Host port for the Chatterbox container (in-container listen port is 4123).
CHATTERBOX_PORT=63045
# Host port for the localhost source variant. URL is derived at compose-render time as http://host.docker.internal:63027.
CHATTERBOX_LOCALHOST_PORT=63027
# Computed by bootstrapper/services/service_config.py::_generate_tts_provider_config — set to 1 when TTS_PROVIDER_SOURCE=chatterbox-container-gpu.
# (auto-managed)
CHATTERBOX_SCALE=

# ──────────────────────────────────────────────────────────────────────────
# llm: Cloud LLM providers (OpenAI, Anthropic, OpenRouter)  (services/cloud-providers/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Options: enabled, disabled.
CLOUD_OPENAI_SOURCE=disabled
# (secret)
OPENAI_API_KEY=
# Comma-separated OpenAI model names the wizard activated.
OPENAI_USER_MODELS=
# Options: enabled, disabled.
CLOUD_ANTHROPIC_SOURCE=disabled
# (secret)
ANTHROPIC_API_KEY=
# Comma-separated Anthropic model names the wizard activated.
ANTHROPIC_USER_MODELS=
# Options: enabled, disabled.
CLOUD_OPENROUTER_SOURCE=disabled
# (secret)
OPENROUTER_API_KEY=
# Comma-separated OpenRouter model names the wizard activated.
OPENROUTER_USER_MODELS=
# Derived from CLOUD_OPENAI_SOURCE.
# (auto-managed)
LITELLM_OPENAI_ENABLED=
# Derived from CLOUD_ANTHROPIC_SOURCE.
# (auto-managed)
LITELLM_ANTHROPIC_ENABLED=
# Derived from CLOUD_OPENROUTER_SOURCE.
# (auto-managed)
LITELLM_OPENROUTER_ENABLED=
# Comma-separated lowercase list of enabled cloud providers.
# (auto-managed)
LITELLM_ENABLED_PROVIDERS=

# ──────────────────────────────────────────────────────────────────────────
# media: ComfyUI (image generation)  (services/comfyui/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container-cpu | container-gpu | localhost | disabled
COMFYUI_SOURCE=container-cpu

# Image references
# Use latest-cuda for GPU.
COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui:v2-cpu-22.04-v0.2.7
COMFYUI_INIT_IMAGE=alpine:latest

COMFYUI_INIT_SOURCE=container
COMFYUI_PORT=63041
# Host port for the localhost source variant. URL is derived at compose-render time as http://host.docker.internal:8000.
COMFYUI_LOCALHOST_PORT=8000
# In-container default. Runtime value is COMFYUI_ENDPOINT computed by hook.
COMFYUI_BASE_URL=http://comfyui:18188
COMFYUI_KONG_URL=http://kong-api-gateway:8000/comfyui
COMFYUI_ARGS=--listen
COMFYUI_AUTO_UPDATE=false
COMFYUI_PLATFORM=linux/amd64
COMFYUI_UPLOAD_TO_SUPABASE=true
COMFYUI_STORAGE_BUCKET=comfyui-images
COMFYUI_MODELS_PATH=/opt/ComfyUI/models
COMFYUI_OUTPUT_PATH=/opt/ComfyUI/output
COMFYUI_INPUT_PATH=/opt/ComfyUI/input
COMFYUI_CUSTOM_NODES_PATH=/opt/ComfyUI/custom_nodes
COMFYUI_LOCAL_MODELS_PATH=~/Documents/ComfyUI/models
# Comma-separated catalog model names the user picked in the wizard (or via --comfyui-models). Read by services/comfyui/init/scripts/download_models.sh.
COMFYUI_USER_MODELS=
# Path inside comfyui-catalog-init to the sidecar custom-models.yaml. Default points at the bind-mounted services/comfyui/custom-models.yaml.
COMFYUI_CUSTOM_MODELS_FILE=/custom-models.yaml
# (auto-managed)
COMFYUI_INIT_SCALE=
# Scale for the comfyui-catalog-init container that UPSERTs public.comfyui_models. Follows COMFYUI_INIT_SCALE (0 when ComfyUI is disabled).
# (auto-managed)
COMFYUI_CATALOG_INIT_SCALE=
# (auto-managed)
COMFYUI_SCALE=
# Resolved per COMFYUI_SOURCE. Consumed by backend, open-webui, n8n, jupyterhub.
# (auto-managed)
COMFYUI_ENDPOINT=
COMFYUI_DEPLOY_RESOURCES=~
# True when COMFYUI_SOURCE=localhost.
# (auto-managed)
IS_LOCAL_COMFYUI=

# ──────────────────────────────────────────────────────────────────────────
# media: Docling (document processor)  (services/docling/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: disabled | docling-localhost | docling-container-gpu
DOC_PROCESSOR_SOURCE=disabled

# Image references
# Used as BASE_IMAGE in doc-processor/gpu/Dockerfile.
DOCLING_GPU_IMAGE=pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

DOC_PROCESSOR_PORT=63040
DOCLING_GPU_DEVICE=cuda
DOCLING_OUTPUT_FORMAT=markdown
DOCLING_USE_OCR=auto
DOCLING_TABLE_MODE=accurate
DOCLING_MAX_FILE_SIZE=52428800
DOCLING_ENABLE_FORMULAS=true
DOCLING_ENABLE_CODE_BLOCKS=true
DOCLING_CHUNK_SIZE=512
DOCLING_CHUNK_OVERLAP=50
# (auto-managed)
DOCLING_GPU_SCALE=
# (auto-managed)
DOCLING_ENDPOINT=
# Host port for the localhost source variant. URL is derived at compose-render time as http://host.docker.internal:63021.
DOCLING_LOCALHOST_PORT=63021

# ──────────────────────────────────────────────────────────────────────────
# infra: Globals (project + branding)  (services/globals/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Project identifier. Used as container/volume/network name prefix.
PROJECT_NAME=genai
# Base port. Every service's *_PORT derives from this + a fixed offset.
BASE_PORT=63000
# Bootstrapper computes this at runtime based on the runtime (Docker:
# "host-gateway"; Podman: literal gateway IP). If you copy this file to
# .env manually without running ./start.sh, set this to "host-gateway"
# on Linux/macOS Docker, or the real bridge IP on rootless setups.
# (auto-managed)
HOST_GATEWAY_IP=
BRAND_NAME=GenAI Vanilla Stack
BRAND_TAGLINE=An opinionated, modular, source-configurable AI stack.
BRAND_VERSION=0.1.0
BRAND_AUTHOR=Kaveh Razavi
BRAND_AUTHOR_EMAIL=kaveh.razavi@gmail.com
BRAND_LICENSE=Apache License 2.0
BRAND_REPO_URL=https://github.com/thekaveh/genai-vanilla
# Host-side GPU visibility. Forwarded into every NVIDIA-runtime container.
NVIDIA_VISIBLE_DEVICES=all
# Default container CPU cap (cores). Per-service overrides below.
PROD_ENV_CPUS=2
PROD_ENV_MEM_LIMIT=8g
PROD_ENV_BACKEND_CPUS=1
PROD_ENV_BACKEND_MEM_LIMIT=2g
PROD_ENV_N8N_CPUS=1
PROD_ENV_N8N_MEM_LIMIT=2g
PROD_ENV_COMFYUI_CPUS=2
PROD_ENV_COMFYUI_MEM_LIMIT=4g
# Sentinel updated by bootstrapper/services/migrations. Missing or <1 triggers port-layout v1 migration on next start.
BOOTSTRAPPER_PORT_LAYOUT_VERSION=1

