# ──────────────────────────────────────────────────────────────────────────
# llm: Ollama (local LLM engine)  (services/ollama/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: ollama-container-cpu | ollama-container-gpu | ollama-localhost | ollama-external | none
LLM_PROVIDER_SOURCE=ollama-container-cpu

# Image references
LLM_PROVIDER_IMAGE=ollama/ollama:latest
OLLAMA_PULL_IMAGE=alpine:latest

# Required when LLM_PROVIDER_SOURCE=ollama-external.
LLM_PROVIDER_EXTERNAL_URL=
# Comma-separated Ollama model names the wizard activated.
OLLAMA_USER_MODELS=
# Free-text extra Ollama models pulled in container-* sources.
OLLAMA_CUSTOM_MODELS=
# When LLM_PROVIDER_SOURCE=ollama-localhost or ollama-external, llm-catalog-init queries the upstream's /api/tags and auto-imports every model found, unioning with OLLAMA_USER_MODELS. Set false to keep strict wizard-only control.
OLLAMA_AUTO_IMPORT_LOCAL_MODELS=true
# Reserved for future GPU deploy block. Currently '~' (null).
OLLAMA_DEPLOY_RESOURCES=~
# (auto-managed)
OLLAMA_SCALE=
# (auto-managed)
OLLAMA_PULL_SCALE=
# (auto-managed)
OLLAMA_NVIDIA_VISIBLE_DEVICES=
# (auto-managed)
OLLAMA_ENDPOINT=
# Ollama URL the LiteLLM gateway forwards Ollama-routed requests to. Owned by ollama because the value flips with LLM_PROVIDER_SOURCE; consumed by litellm-init when rendering its config.yaml.
# (auto-managed)
LITELLM_OLLAMA_UPSTREAM=

