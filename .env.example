ZEPPELIN_SOURCE=disabled

# Image references
ZEPPELIN_IMAGE=apache/zeppelin:0.12.0

# Host port for the Zeppelin Web UI (in-container 8080).
ZEPPELIN_PORT=63084
# (auto-managed)
ZEPPELIN_SCALE=
