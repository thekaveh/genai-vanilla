# ──────────────────────────────────────────────────────────────────────────
# media: Parakeet (NVIDIA STT engine)  (services/parakeet/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: speaches-container-cpu | speaches-container-gpu | parakeet-container-gpu | parakeet-localhost | whisper-cpp-localhost | disabled
STT_PROVIDER_SOURCE=speaches-container-cpu

# Image references
# Used as BASE_IMAGE in stt-provider/gpu/Dockerfile.
PARAKEET_GPU_IMAGE=nvcr.io/nvidia/pytorch:25.01-py3

# Wizard display slot. Real per-engine ports live on their own manifests (PARAKEET_*, SPEACHES_*, etc.).
STT_PROVIDER_PORT=63042
# Aggregate STT scale across all engines. Reserved for future use.
# (auto-managed)
STT_PROVIDER_SCALE=
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3
PARAKEET_GPU_DEVICE=cuda
PARAKEET_GPU_COMPUTE_TYPE=float16
PARAKEET_LOCALHOST_URL=http://host.docker.internal:63022
# Used when STT_PROVIDER_SOURCE=whisper-cpp-localhost.
WHISPER_CPP_LOCALHOST_URL=http://host.docker.internal:63025
# Shared by parakeet, speaches, chatterbox, docling for model downloads. Consumed by ${HUGGING_FACE_HUB_TOKEN} interpolation in those services' compose blocks; owned here as its historic home.
# (secret)
HUGGING_FACE_HUB_TOKEN=
# (auto-managed)
PARAKEET_GPU_SCALE=
# Resolved per STT_PROVIDER_SOURCE. Consumed by n8n, backend, jupyterhub, open-webui, hermes-init (the latter as STT_INTERNAL_URL — owned by services/hermes/).
# (auto-managed)
STT_ENDPOINT=

# ──────────────────────────────────────────────────────────────────────────
# data: Redis (cache & queue)  (services/redis/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
# Bumping the redis version: change this default and rerun ./start.sh.
REDIS_IMAGE=redis:7.2-alpine

# Single-option source toggle. Redis only ever runs as a container.
# Kept as an env entry (rather than a sources: block) so the wizard
# does not render a one-option dropdown. The legacy source validator
# still expects REDIS_SOURCE=container until Phase D.
REDIS_SOURCE=container
# Host port. Container port is always 6379.
REDIS_PORT=63021
# Used by every consumer (n8n queue, kong rate-limit cache,
# open-webui websocket store, backend session/queue, local-deep-
# researcher worker queue). The default is for fresh-install
# convenience only; rotate before any deployment.
# (secret)
REDIS_PASSWORD=
# Default connection string (database index 0). Consumers that need a
# different DB index build their own URL (open-webui uses /2,
# local-deep-researcher uses /3). REDIS_PASSWORD is substituted at
# compose-interpolation time.
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ──────────────────────────────────────────────────────────────────────────
# media: SearXNG (privacy metasearch)  (services/searxng/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | disabled
SEARXNG_SOURCE=container

# Image references
SEARXNG_IMAGE=searxng/searxng:latest

SEARXNG_PORT=63043
# Auto-generated by bootstrapper.
# (secret)
SEARXNG_SECRET=
SEARXNG_PUBLIC_INSTANCE=false
SEARXNG_ENABLE_METRICS=true
SEARXNG_DEFAULT_LOCALE=en
# (auto-managed)
SEARXNG_SCALE=

# ──────────────────────────────────────────────────────────────────────────
# media: Speaches (unified TTS + STT)  (services/speaches/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
# CPU build (default). GPU build is SPEACHES_GPU_IMAGE; the speaches-gpu profile selects it.
SPEACHES_IMAGE=ghcr.io/speaches-ai/speaches:0.9.0-rc.3-cpu

# CUDA build of the same image; not yet wired to image var.
SPEACHES_GPU_IMAGE=ghcr.io/speaches-ai/speaches:0.9.0-rc.3-cuda
# Model name Open WebUI sends in /v1/audio/speech requests.
SPEACHES_TTS_MODEL=hexgrad/Kokoro-82M
SPEACHES_STT_MODEL=Systran/faster-distil-whisper-large-v3
# Slot +26.
SPEACHES_PORT=63046
# Computed by bootstrapper/services/service_config.py::_generate_stt_provider_config (or _generate_tts_provider_config) — set to 1 when STT_PROVIDER_SOURCE OR TTS_PROVIDER_SOURCE picks a speaches-* variant.
# (auto-managed)
SPEACHES_SCALE=

# ──────────────────────────────────────────────────────────────────────────
# data: Supabase (db, auth, api, storage, realtime, studio, meta)  (services/supabase/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Image references
SUPABASE_DB_IMAGE=supabase/postgres:17.4.1.016
SUPABASE_DB_INIT_IMAGE=postgres:15-alpine
SUPABASE_META_IMAGE=supabase/postgres-meta:v0.88.9
SUPABASE_STORAGE_IMAGE=supabase/storage-api:v1.22.7
SUPABASE_AUTH_IMAGE=supabase/gotrue:v2.171.0
SUPABASE_API_IMAGE=postgrest/postgrest:v12.2.10
SUPABASE_REALTIME_IMAGE=supabase/realtime:v2.33.72
SUPABASE_STUDIO_IMAGE=supabase/studio:latest

# Single-option (container only). Kept for forward-compat with legacy source-validator.
SUPABASE_DB_SOURCE=container
SUPABASE_DB_PORT=63010
SUPABASE_DB_USER=supabase_admin
# (secret)
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres
# Application-tier user (created by supabase-db-init scripts).
SUPABASE_DB_APP_USER=app_user
# (secret)
SUPABASE_DB_APP_PASSWORD=
# Auto-managed by supabase-db. Container/disabled.
SUPABASE_DB_INIT_SOURCE=container
SUPABASE_META_SOURCE=container
SUPABASE_META_PORT=63011
SUPABASE_STORAGE_SOURCE=container
SUPABASE_STORAGE_PORT=63012
STORAGE_REGION=local
STORAGE_FILE_SIZE_LIMIT=52428800
STORAGE_BACKEND=file
PROJECT_REF=default
TENANT_ID=stub
SUPABASE_AUTH_SOURCE=container
SUPABASE_AUTH_PORT=63013
# Auto-generated by bootstrapper/generate_supabase_keys.py on first run.
# (secret)
SUPABASE_JWT_SECRET=
# Auto-generated.
# (secret)
SUPABASE_ANON_KEY=
# Auto-generated.
# (secret)
SUPABASE_SERVICE_KEY=
SUPABASE_API_SOURCE=container
SUPABASE_API_PORT=63014
SUPABASE_REALTIME_SOURCE=container
SUPABASE_REALTIME_PORT=63015
SUPABASE_STUDIO_SOURCE=container
SUPABASE_STUDIO_PORT=63016

# ──────────────────────────────────────────────────────────────────────────
# media: TTS provider (text-to-speech engine selector)  (services/tts-provider/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: speaches-container-cpu | speaches-container-gpu | chatterbox-container-gpu | chatterbox-localhost | disabled
TTS_PROVIDER_SOURCE=speaches-container-cpu

# Wizard display slot. Real engine port lives on its own container manifest.
TTS_PROVIDER_PORT=63044
# Aggregate scale across all TTS engines. Reserved for future use.
# (auto-managed)
TTS_PROVIDER_SCALE=
# Resolved per TTS_PROVIDER_SOURCE. Consumed by n8n, backend, jupyterhub, open-webui, hermes-init (as TTS_INTERNAL_URL — owned by services/hermes/).
# (auto-managed)
TTS_ENDPOINT=

# ──────────────────────────────────────────────────────────────────────────
# data: Weaviate (vector database)  (services/weaviate/service.yml)
# ──────────────────────────────────────────────────────────────────────────
# Source variant. Options: container | localhost | disabled
WEAVIATE_SOURCE=container

# Image references
WEAVIATE_IMAGE=cr.weaviate.io/semitechnologies/weaviate:1.27.5
WEAVIATE_INIT_IMAGE=alpine:latest
MULTI2VEC_CLIP_IMAGE=semitechnologies/multi2vec-clip:sentence-transformers-clip-ViT-B-32

WEAVIATE_PORT=63022
WEAVIATE_GRPC_PORT=63023
# Auto-managed by weaviate. Container/disabled.
WEAVIATE_INIT_SOURCE=container
# Options: container-cpu, container-gpu, disabled. (Effects driven by hook.)
MULTI2VEC_CLIP_SOURCE=container-cpu
WEAVIATE_ENABLE_MODULES=text2vec-openai,text2vec-ollama,multi2vec-clip,generative-openai,generative-ollama
CLIP_INFERENCE_API=http://multi2vec-clip:8080
# Resolved per WEAVIATE_SOURCE. Consumed by n8n, backend, jupyterhub.
# (auto-managed)
WEAVIATE_URL=
# User-settable. Mirrors what Weaviate's text2vec-ollama vectorizer hits; matches OLLAMA_ENDPOINT for container source, but the user adjusts manually for ollama-localhost/external (consistent with main's behavior).
WEAVIATE_OLLAMA_ENDPOINT=http://ollama:11434
# Computed by hook from LITELLM_PORT + BASE_PORT.
# (auto-managed)
WEAVIATE_LITELLM_BASE_URL=
# Mirror of LITELLM_MASTER_KEY for Weaviate's vectorizer auth.
# (auto-managed, secret)
WEAVIATE_LITELLM_API_KEY=
# (auto-managed)
WEAVIATE_SCALE=
# (auto-managed)
WEAVIATE_INIT_SCALE=
# Computed from MULTI2VEC_CLIP_SOURCE.
# (auto-managed)
CLIP_SCALE=
# (auto-managed)
CLIP_ENABLE_CUDA=
CLIP_DEPLOY_RESOURCES=~
