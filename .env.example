PARAKEET_LOCALHOST_PORT=63042
# Host port for the localhost source variant (defaults to the freed STT_PROVIDER_PORT slot, same as parakeet — the two modes are mutually exclusive). URL is derived at compose-render time as http://host.docker.internal:63042.
WHISPER_CPP_LOCALHOST_PORT=63042
# Shared by parakeet, speaches, chatterbox, docling for model downloads. Consumed by ${HUGGING_FACE_HUB_TOKEN} interpolation in those services' compose blocks; owned here as its historic home.
