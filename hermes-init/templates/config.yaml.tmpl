# GENERATED by hermes-init/scripts/init-hermes.sh on container start.
# DO NOT edit by hand — change behavior via env vars in the .env file
# (HERMES_DEFAULT_MODEL, HERMES_CONTEXT_LENGTH, etc.) and restart the stack.
#
# Hermes config schema reference:
#   https://hermes-agent.nousresearch.com/docs/user-guide/configuration

# ─── LLM model ────────────────────────────────────────────────────────
# All LLM traffic flows through the stack's LiteLLM gateway. Hermes
# requires a >=64K context window (preflight check); the model named
# below MUST satisfy that.
model:
  default: ${HERMES_DEFAULT_MODEL}
  provider: custom
  base_url: http://litellm:4000/v1
  api_key: ${LITELLM_MASTER_KEY}
  context_length: ${HERMES_CONTEXT_LENGTH}

# ─── TTS — XTTS via openedai-speech ───────────────────────────────────
# BEGIN-TTS
tts:
  provider: openai
  base_url: ${XTTS_INTERNAL_URL}/v1
  api_key: not-required
  model: tts-1-hd
  voice: alloy
# END-TTS

# ─── STT — Parakeet via OpenAI-compatible whisper endpoint ────────────
# Hermes documents base_url override for the OpenAI TTS provider; the
# STT override is not explicitly documented and may need a fallback to
# command-type provider. See docs/services/hermes.md "Known caveats".
# BEGIN-STT
stt:
  provider: openai
  base_url: ${PARAKEET_INTERNAL_URL}/v1
  api_key: not-required
  model: whisper-1
# END-STT

# ─── Web search — SearXNG ─────────────────────────────────────────────
# BEGIN-SEARCH
search:
  provider: searxng
  base_url: ${SEARXNG_INTERNAL_URL}
# END-SEARCH

# ─── Custom providers ─────────────────────────────────────────────────
# Named providers for skills/tools that want to address LiteLLM by
# name rather than via the default model alias.
custom_providers:
  - name: litellm
    base_url: http://litellm:4000/v1
    key_env: LITELLM_MASTER_KEY
