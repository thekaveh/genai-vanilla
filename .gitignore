# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
# Tracked service-folder 'build/' dirs (Docker image source) — exempt from
# the generic Python-build-artifact pattern above so 'git add' on tracked
# files inside them doesn't warn/exit-non-zero on every new file.
!services/*/build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
.env
.venv
env/
venv/
*venv/
ENV/
env.bak/
venv.bak/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebooks
.ipynb_checkpoints

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Local development settings
.DS_Store

# Logs
logs/
*.log

# Database files
*.sqlite3
*.db

# Docker volumes
data/
# Bundled source-data package for the bootstrapper — not a Docker volume
!bootstrapper/utils/data/

# Auto-generated runtime artifacts under volumes/ — never hand-edit; the
# bootstrapper / init containers rewrite these on every ./start.sh.
# Narrow patterns (file/glob, not directory) so a future hand-checked
# file under volumes/litellm/ — plugins, custom prompts, anything we
# might want to track — doesn't get silently hidden by a directory glob.
volumes/api/kong-dynamic.yml
volumes/litellm/config.yaml
volumes/litellm/*.yml

# Environment variables file
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.backup.*

# Temp files
.tmp/
tmp/

# Model files, weights, etc.
*.bin
*.pt
*.pth
*.hdf5
*.h5

# Archive files
*.zip
*.tar.gz
*.tgz

# uv specific
.uv/

# Project specific
.claude/
CLAUDE.md

.kilo
opencode.json
.superpowers

# Personal scratch / demo files that don't belong to the project
ascii_drape_water_demo.py
ascii_drape_water_out/
# Downstream submodule consumers' overlay slot — `services/_user/<name>/`
# folders are loaded by the manifest loader (the loader still skips `_user`
# itself but a custom downstream loader can be configured to read its
# children). Local-only by default; not tracked in the upstream repo.
services/_user/

# Audit working tree (overnight audit logs)
.audit/

# ComfyUI picker — local catalog cache (TTL-bounded; safe to delete)
bootstrapper/.cache/

# ComfyUI picker — snapshot emitted by bootstrapper for the init container
volumes/api/comfyui-catalog-snapshot.json
